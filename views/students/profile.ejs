<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <style>
        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            padding: 48px 0 0;
            box-shadow: inset -1px 0 0 rgba(0, 0, 0, .1);
        }
        .sidebar-sticky {
            height: calc(100vh - 48px);
            overflow-x: hidden;
            overflow-y: auto;
        }
        .nav-link {
            color: #333;
            padding: 0.5rem 1rem;
            margin: 0.2rem 0;
        }
        .nav-link:hover {
            background-color: #f8f9fa;
        }
        .nav-link.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .nav-link i {
            margin-right: 10px;
        }
        main {
            padding-top: 48px;
        }
        .profile-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 0;
            margin-bottom: 30px;
            border-radius: 0 0 50px 50px;
        }
        .profile-avatar {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            border: 5px solid white;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
            object-fit: cover;
        }
        .profile-name {
            margin-top: 15px;
            font-size: 28px;
            font-weight: 600;
        }
        .profile-role {
            font-size: 16px;
            opacity: 0.9;
        }
        .info-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            padding: 25px;
            margin-bottom: 25px;
            transition: transform 0.3s;
        }
        .info-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .info-card h5 {
            color: #495057;
            border-bottom: 2px solid #e9ecef;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }
        .info-card h5 i {
            margin-right: 10px;
            color: #667eea;
        }
        .info-item {
            margin-bottom: 15px;
        }
        .info-label {
            font-weight: 600;
            color: #6c757d;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .info-value {
            font-size: 16px;
            color: #212529;
            margin-top: 5px;
        }
        .status-badge {
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
            display: inline-block;
        }
        .status-active {
            background: #d4edda;
            color: #155724;
        }
        .status-inactive {
            background: #f8d7da;
            color: #721c24;
        }
        .stat-card {
            background: white;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }
        .stat-card h3 {
            font-size: 32px;
            font-weight: 700;
            margin: 10px 0;
            color: #667eea;
        }
        .stat-card p {
            color: #6c757d;
            margin: 0;
        }
        .stat-card i {
            font-size: 40px;
            color: #764ba2;
        }
        .action-buttons {
            position: sticky;
            top: 70px;
        }
        .btn-action {
            width: 100%;
            margin-bottom: 10px;
            padding: 12px;
            border-radius: 8px;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-2 d-none d-md-block bg-light sidebar">
                <div class="sidebar-sticky">
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted">
                        <span>Main Menu</span>
                    </h6>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" href="/dashboard">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link active" href="/students">
                                <i class="bi bi-people"></i> Students
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/teachers">
                                <i class="bi bi-person-badge"></i> Teachers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/classes">
                                <i class="bi bi-book"></i> Classes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/fees">
                                <i class="bi bi-cash"></i> Fees
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/attendance">
                                <i class="bi bi-calendar-check"></i> Attendance
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/exams">
                                <i class="bi bi-pencil"></i> Exams
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/auth/logout">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-10 ms-sm-auto px-md-4">
                <!-- Profile Header -->
                <div class="profile-header text-center">
                    <div class="container">
                        <img src="<%= student.profilePicture || '/images/default-avatar.png' %>" 
                             alt="<%= student.firstName %>" class="profile-avatar">
                        <h1 class="profile-name"><%= student.firstName %> <%= student.lastName %></h1>
                        <p class="profile-role">
                            <i class="bi bi-person-badge"></i> 
                            Student ID: <%= student.admissionNumber || 'N/A' %>
                        </p>
                    </div>
                </div>

                <div class="container-fluid px-4">
                    <div class="row">
                        <!-- Left Column - Action Buttons -->
                        <div class="col-md-3">
                            <div class="action-buttons">
                                <a href="/students" class="btn btn-outline-secondary btn-action">
                                    <i class="bi bi-arrow-left"></i> Back to List
                                </a>
                                <a href="/students/edit/<%= student._id %>" class="btn btn-warning btn-action">
                                    <i class="bi bi-pencil"></i> Edit Profile
                                </a>
                                <button onclick="printProfile()" class="btn btn-outline-primary btn-action">
                                    <i class="bi bi-printer"></i> Print Profile
                                </button>
                            </div>

                            <!-- Quick Stats -->
                            <div class="stat-card">
                                <i class="bi bi-calendar-check"></i>
                                <h3><%= stats && stats.attendanceRate !== null ? stats.attendanceRate + '%' : 'N/A' %></h3>
                                <p>Attendance Rate</p>
                            </div>
                            <div class="stat-card">
                                <i class="bi bi-trophy"></i>
                                <h3><%= stats && stats.averageMarks ? stats.averageMarks : 'N/A' %></h3>
                                <p>Average Marks</p>
                            </div>
                            <div class="stat-card">
                                <i class="bi bi-cash"></i>
                                <h3>₹<%= stats && stats.feesPaid ? stats.feesPaid.toLocaleString() : 0 %></h3>
                                <p>Fees Paid</p>
                            </div>
                        </div>

                        <!-- Right Column - Profile Information -->
                        <div class="col-md-9">
                            <!-- Status Alert -->
                            <% if (student.status === 'Active') { %>
                                <div class="alert alert-success">
                                    <i class="bi bi-check-circle"></i> This student is currently active.
                                </div>
                            <% } else { %>
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle"></i> Status: <%= student.status %>
                                </div>
                            <% } %>

                            <!-- Personal Information -->
                            <div class="info-card">
                                <h5><i class="bi bi-person"></i> Personal Information</h5>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="info-item">
                                            <div class="info-label">Full Name</div>
                                            <div class="info-value"><%= student.firstName %> <%= student.lastName %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="info-item">
                                            <div class="info-label">Date of Birth</div>
                                            <div class="info-value">
                                                <%= student.dateOfBirth ? new Date(student.dateOfBirth).toLocaleDateString() : 'N/A' %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="info-item">
                                            <div class="info-label">Gender</div>
                                            <div class="info-value"><%= student.gender ? student.gender.charAt(0).toUpperCase() + student.gender.slice(1) : 'N/A' %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="info-item">
                                            <div class="info-label">Blood Group</div>
                                            <div class="info-value"><%= student.bloodGroup || 'N/A' %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Contact Information -->
                            <div class="info-card">
                                <h5><i class="bi bi-envelope"></i> Contact Information</h5>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="info-item">
                                            <div class="info-label">Email Address</div>
                                            <div class="info-value">
                                                <a href="mailto:<%= student.email %>"><%= student.email %></a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="info-item">
                                            <div class="info-label">Phone Number</div>
                                            <div class="info-value">
                                                <a href="tel:<%= student.phoneNumber %>"><%= student.phoneNumber || 'N/A' %></a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Address Information -->
                            <div class="info-card">
                                <h5><i class="bi bi-geo-alt"></i> Address Information</h5>
                                <% if (student.address) { %>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="info-item">
                                                <div class="info-label">Street Address</div>
                                                <div class="info-value"><%= student.address.street || 'N/A' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="info-item">
                                                <div class="info-label">City</div>
                                                <div class="info-value"><%= student.address.city || 'N/A' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="info-item">
                                                <div class="info-label">State</div>
                                                <div class="info-value"><%= student.address.state || 'N/A' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="info-item">
                                                <div class="info-label">ZIP Code</div>
                                                <div class="info-value"><%= student.address.zipCode || 'N/A' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="info-item">
                                                <div class="info-label">Country</div>
                                                <div class="info-value"><%= student.address.country || 'N/A' %></div>
                                            </div>
                                        </div>
                                    </div>
                                <% } else { %>
                                    <p class="text-muted">No address information available.</p>
                                <% } %>
                            </div>

                            <!-- Academic Information -->
                            <div class="info-card">
                                <h5><i class="bi bi-book"></i> Academic Information</h5>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Class/Grade</div>
                                            <div class="info-value"><%= student.class ? student.class.className + ' ' + (student.class.section || '') : 'Not Assigned' %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Roll Number</div>
                                            <div class="info-value"><%= student.rollNumber || 'N/A' %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Admission Date</div>
                                            <div class="info-value">
                                                <%= student.admissionDate ? new Date(student.admissionDate).toLocaleDateString() : 'N/A' %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Parent/Guardian Information -->
                            <div class="info-card">
                                <h5><i class="bi bi-people"></i> Parent/Guardian Information</h5>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Parent Name</div>
                                            <div class="info-value"><%= student.parentName || 'N/A' %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Parent Phone</div>
                                            <div class="info-value">
                                                <% if (student.parentPhone) { %>
                                                    <a href="tel:<%= student.parentPhone %>"><%= student.parentPhone %></a>
                                                <% } else { %>
                                                    N/A
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Parent Email</div>
                                            <div class="info-value">
                                                <% if (student.parentEmail) { %>
                                                    <a href="mailto:<%= student.parentEmail %>"><%= student.parentEmail %></a>
                                                <% } else { %>
                                                    N/A
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Medical Information -->
                            <div class="info-card">
                                <h5><i class="bi bi-heart-pulse"></i> Medical Information</h5>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="info-item">
                                            <div class="info-label">Allergies/Medical Conditions</div>
                                            <div class="info-value"><%= student.allergies || 'None reported' %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- System Information -->
                            <div class="info-card">
                                <h5><i class="bi bi-gear"></i> System Information</h5>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Student ID</div>
                                            <div class="info-value"><%= student._id %></div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Created At</div>
                                            <div class="info-value">
                                                <%= student.createdAt ? new Date(student.createdAt).toLocaleDateString() : 'N/A' %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Last Updated</div>
                                            <div class="info-value">
                                                <%= student.updatedAt ? new Date(student.updatedAt).toLocaleDateString() : 'N/A' %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Last Login</div>
                                            <div class="info-value">
                                                <%= student.lastLogin ? new Date(student.lastLogin).toLocaleDateString() : 'Never' %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="info-item">
                                            <div class="info-label">Status</div>
                                            <div class="info-value">
                                                <% if (student.status === 'Active') { %>
                                                    <span class="status-badge status-active">Active</span>
                                                <% } else { %>
                                                    <span class="status-badge status-inactive"><%= student.status || 'Inactive' %></span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Print profile function
        function printProfile() {
            window.print();
        }

        // Confirm delete
        function confirmDelete() {
            if (confirm('Are you sure you want to delete this student? This action cannot be undone.')) {
                window.location.href = '/students/delete/<%= student._id %>';
            }
        }
    </script>

    <!-- Print Styles -->
    <style media="print">
        .sidebar, .action-buttons, .btn, .alert, .profile-header {
            display: none !important;
        }
        main {
            margin-left: 0 !important;
            width: 100% !important;
        }
        .info-card {
            break-inside: avoid;
            box-shadow: none;
            border: 1px solid #dee2e6;
        }
    </style>
</body>
</html>