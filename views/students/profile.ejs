<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Student Profile Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Student Profile</h2>
                        <p class="text-muted small mb-0">Review personal, academic, and financial details for the student.</p>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Left Column: Primary Profile Info -->
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm p-4 text-center mb-4">
                            <div class="profile-avatar-container mb-3 text-center position-relative mx-auto">
                                <img src="/uploads/<%= student.profilePicture || 'default-avatar.png' %>" 
                                     alt="Profile" 
                                     class="rounded-circle shadow-md border"
                                     style="width: 140px; height: 140px; object-fit: cover; border-width: 5px !important; border-color: #fff !important;">
                                <div class="badge rounded-pill bg-<%= student.isActive ? 'success' : 'danger' %> position-absolute bottom-0 start-100 translate-middle border border-4 border-white" style="width: 15px; height: 15px; padding: 0;"></div>
                            </div>
                            <h4 class="mb-1 text-main"><%= student.firstName %> <%= student.lastName %></h4>
                            <p class="text-muted small fw-bold text-uppercase letter-spacing-1 mb-4">
                                <%= student.admissionNumber %> / <%= student.class ? student.class.className : 'UNASSIGNED' %>
                            </p>
                            
                            <div class="row g-2">
                                <div class="col-6">
                                    <a href="/students/<%= student._id %>/edit" class="btn btn-primary btn-sm w-100 rounded-8"><i class="bi bi-pencil me-1"></i>Edit</a>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-secondary btn-sm w-100 rounded-8"><i class="bi bi-download me-1"></i>Report</button>
                                </div>
                            </div>
                        </div>

                        <!-- Academic Quick Stats -->
                        <div class="card border-0 shadow-sm p-4">
                            <h6 class="mb-4 text-muted small text-uppercase fw-bold"><i class="bi bi-graph-up me-2"></i>Academic Summary</h6>
                            <div class="stats-list">
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="stats-icon bg-success bg-opacity-10 text-success mb-0" style="width: 38px; height: 38px; font-size: 1rem;">
                                            <i class="bi bi-calendar2-check"></i>
                                        </div>
                                        <div class="small fw-medium text-muted">Attendance</div>
                                    </div>
                                    <div class="fw-bold h6 mb-0"><%= stats.attendanceRate %>%</div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="stats-icon bg-primary bg-opacity-10 text-primary mb-0" style="width: 38px; height: 38px; font-size: 1rem;">
                                            <i class="bi bi-star"></i>
                                        </div>
                                        <div class="small fw-medium text-muted">Avg. Score</div>
                                    </div>
                                    <div class="fw-bold h6 mb-0 text-primary"><%= stats.averageMarks %>%</div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="stats-icon bg-warning bg-opacity-10 text-warning mb-0" style="width: 38px; height: 38px; font-size: 1rem;">
                                            <i class="bi bi-currency-dollar"></i>
                                        </div>
                                        <div class="small fw-medium text-muted">Fees Paid</div>
                                    </div>
                                    <div class="fw-bold h6 mb-0 text-warning">KES <%= stats.feesPaid.toLocaleString() %></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Details & Details -->
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm p-4 mb-4">
                            <ul class="nav nav-tabs border-0 gap-4 mb-4" id="profileTab" role="tablist">
                                <li class="nav-item">
                                    <button class="nav-link active border-0 bg-transparent py-2 px-0 fw-bold small text-uppercase" id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab">General Information</button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link border-0 bg-transparent py-2 px-0 fw-bold small text-uppercase" id="parents-tab" data-bs-toggle="tab" data-bs-target="#parents" type="button" role="tab">Parents & Contact</button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link border-0 bg-transparent py-2 px-0 fw-bold small text-uppercase" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab">Academics History</button>
                                </li>
                            </ul>
                            
                            <div class="tab-content" id="profileTabContent">
                                <!-- General Info Tab -->
                                <div class="tab-pane fade show active" id="info" role="tabpanel">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-12 border border-light">
                                                <div class="text-muted small mb-1 fw-bold">Gender</div>
                                                <div class="text-main fw-medium"><%= student.gender || 'Not specified' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-12 border border-light">
                                                <div class="text-muted small mb-1 fw-bold">Date of Birth</div>
                                                <div class="text-main fw-medium"><%= moment(student.dateOfBirth).format('MMMM DD, YYYY') %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-12 border border-light">
                                                <div class="text-muted small mb-1 fw-bold">Section</div>
                                                <div class="text-main fw-medium"><%= student.class ? student.class.section : 'UNASSIGNED' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-12 border border-light">
                                                <div class="text-muted small mb-1 fw-bold">Admission Date</div>
                                                <div class="text-main fw-medium"><%= moment(student.admissionDate).format('MMMM DD, YYYY') %></div>
                                            </div>
                                        </div>
                                        <div class="col-12 mt-4">
                                            <div class="p-4 bg-light bg-opacity-50 rounded-12 border">
                                                <div class="text-muted small mb-2 fw-bold"><i class="bi bi-geo-alt me-2"></i>Residential Address</div>
                                                <div class="text-main"><%= student.address || 'Address information not provided yet.' %></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Parents Tab -->
                                <div class="tab-pane fade" id="parents" role="tabpanel">
                                    <div class="alert alert-info border-0 shadow-sm rounded-12 p-4 d-flex gap-3 align-items-center mb-4">
                                        <i class="bi bi-info-circle-fill fs-3"></i>
                                        <div class="small fw-medium">Emergency notification alerts are sent to the phone number and email listed below.</div>
                                    </div>
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-12 border">
                                                <div class="text-muted small mb-1 fw-bold">Guardian Email</div>
                                                <div class="text-main fw-medium"><%= student.email || 'N/A' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-12 border">
                                                <div class="text-muted small mb-1 fw-bold">Emergency Contact</div>
                                                <div class="text-main fw-medium text-primary fw-bold"><%= student.phoneNumber %></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- History Tab -->
                                <div class="tab-pane fade" id="history" role="tabpanel">
                                    <div class="text-center py-5">
                                        <i class="bi bi-clock-history display-1 opacity-10 mb-3"></i>
                                        <p class="text-muted fw-medium">Academic term history will appear here once records are finalized.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Recent Performance Chart -->
                        <div class="card border-0 shadow-sm p-4">
                            <h6 class="mb-4 text-muted small text-uppercase fw-bold">Progress Chart</h6>
                            <div style="height: 250px;">
                                <canvas id="progressChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Progress Chart
        const progressCtx = document.getElementById('progressChart').getContext('2d');
        new Chart(progressCtx, {
            type: 'line',
            data: {
                labels: ['Term 1', 'Term 2', 'Term 3', 'Finals'],
                datasets: [{
                    label: 'Marks (%)',
                    data: [78, 82, 85, 84],
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99, 102, 241, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 6,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, max: 100, ticks: { font: { family: 'Inter', size: 10 } } },
                    x: { ticks: { font: { family: 'Inter', size: 10 } } }
                }
            }
        });
        
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>