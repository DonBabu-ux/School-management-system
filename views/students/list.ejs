<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Student Management Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Students Management</h2>
                        <p class="text-muted small mb-0">Manage student records, admissions, and academic status.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/students/export" class="btn btn-outline-secondary border-0 bg-white shadow-sm">
                            <i class="bi bi-download me-2"></i>Export
                        </a>
                        <a href="/students/add" class="btn btn-primary">
                            <i class="bi bi-person-plus-fill me-2"></i>Add Student
                        </a>
                    </div>
                </div>

                <!-- Filters Card -->
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <form action="/students" method="GET" class="row g-3">
                        <div class="col-md-5">
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                                <input type="text" name="search" class="form-control bg-light border-0" 
                                       placeholder="Search by name or admission number..." value="<%= searchQuery %>">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <select name="classId" class="form-select bg-light border-0">
                                <option value="">All Classes</option>
                                <% classes.forEach(c => { %>
                                    <option value="<%= c._id %>" <%= selectedClass == c._id ? 'selected' : '' %>>
                                        <%= c.className %> - <%= c.section %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Filter</button>
                        </div>
                        <div class="col-md-2">
                            <a href="/students" class="btn btn-light w-100 border text-muted">Reset</a>
                        </div>
                    </form>
                </div>

                <!-- Student Table Card -->
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 border-0 text-uppercase small text-muted font-monospace py-3">Student info</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Admission ID</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Class</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Phone</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Status</th>
                                    <th class="pe-4 border-0 text-uppercase small text-muted font-monospace py-3 text-end">Options</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (students && students.length > 0) { %>
                                    <% students.forEach(student => { %>
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center gap-3">
                                                    <img src="/uploads/<%= student.profilePicture || 'default-avatar.png' %>" 
                                                         alt="Avatar" class="rounded-circle border" 
                                                         style="width: 40px; height: 40px; object-fit: cover;">
                                                    <div>
                                                        <div class="fw-bold text-main small"><%= student.firstName %> <%= student.lastName %></div>
                                                        <div class="text-muted" style="font-size: 11px;"><%= student.email %></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="py-3">
                                                <span class="badge bg-light text-muted fw-bold border" style="font-size: 10px;">
                                                    <%= student.admissionNumber %>
                                                </span>
                                            </td>
                                            <td class="py-3">
                                                <span class="small fw-medium text-secondary">
                                                    <%= student.class ? student.class.className + ' - ' + student.class.section : 'Not Assigned' %>
                                                </span>
                                            </td>
                                            <td class="py-3">
                                                <span class="small text-muted"><%= student.phoneNumber || 'N/A' %></span>
                                            </td>
                                            <td class="py-3">
                                                <% if (student.isActive) { %>
                                                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 border border-success border-opacity-25" style="font-size: 10px;">ACTIVE</span>
                                                <% } else { %>
                                                    <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 border border-danger border-opacity-25" style="font-size: 10px;">INACTIVE</span>
                                                <% } %>
                                            </td>
                                            <td class="pe-4 py-3 text-end">
                                                <div class="dropdown">
                                                    <button class="btn btn-icon btn-sm text-muted border-0 bg-transparent" data-bs-toggle="dropdown">
                                                        <i class="bi bi-three-dots-vertical"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 rounded-12">
                                                        <li><a class="dropdown-item p-2 rounded-8" href="/students/<%= student._id %>"><i class="bi bi-eye me-2"></i> View Profile</a></li>
                                                        <li><a class="dropdown-item p-2 rounded-8" href="/students/<%= student._id %>/edit"><i class="bi bi-pencil me-2"></i> Edit Student</a></li>
                                                        <li><hr class="dropdown-divider"></li>
                                                        <li>
                                                            <button class="dropdown-item p-2 rounded-8 text-danger" onclick="confirmDelete('<%= student._id %>')">
                                                                <i class="bi bi-trash me-2"></i> Delete
                                                            </button>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="text-muted d-flex flex-column align-items-center">
                                                <i class="bi bi-people display-4 mb-2 opacity-25"></i>
                                                <p class="mb-0">No students found matching your criteria</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modals -->
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-20">
                <div class="modal-body p-5 text-center">
                    <div class="stats-icon bg-danger text-white mx-auto mb-4" style="width: 64px; height: 64px; font-size: 2rem;">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <h4 class="mb-3">Are you sure?</h4>
                    <p class="text-muted mb-4">You are about to delete this student record. This action is permanent and cannot be undone.</p>
                    <div class="d-flex gap-3 justify-content-center">
                        <button type="button" class="btn btn-light px-4 border" data-bs-dismiss="modal">Cancel</button>
                        <a href="#" id="confirmDeleteBtn" class="btn btn-danger px-4">Delete Record</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function confirmDelete(id) {
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            document.getElementById('confirmDeleteBtn').href = '/students/' + id + '/delete';
            modal.show();
        }
        
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>