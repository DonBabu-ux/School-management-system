<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Add Student Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Add New Student</h2>
                        <p class="text-muted small mb-0">Follow the steps below to admit a new student to the institution.</p>
                    </div>
                    <a href="/students" class="btn btn-outline-secondary border-0 bg-white shadow-sm">
                        <i class="bi bi-arrow-left me-2"></i>Back to List
                    </a>
                </div>

                <% if (error) { %>
                    <div class="alert alert-danger mb-4 shadow-sm border-0 d-flex align-items-center">
                        <i class="bi bi-exclamation-octagon-fill me-3 fs-3"></i>
                        <div>
                            <div class="fw-bold">Registration Error</div>
                            <%= error %>
                        </div>
                    </div>
                <% } %>

                <form action="/students/add" method="POST" enctype="multipart/form-data">
                    <div class="row g-4">
                        <!-- Personal Information -->
                        <div class="col-lg-8">
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="p-4 border-bottom d-flex align-items-center gap-3">
                                    <div class="stats-icon bg-primary text-white mb-0" style="width: 32px; height: 32px; font-size: 1rem;">
                                        <i class="bi bi-person-bounding-box"></i>
                                    </div>
                                    <h5 class="mb-0">Personal Information</h5>
                                </div>
                                <div class="card-body p-4">
                                    <div class="row g-3">
                                        <div class="col-md-6 mb-4">
                                        <label class="form-label fw-bold small text-muted">Admission Number</label>
                                        <input type="text" name="admissionNumber" class="form-control bg-light border-0 py-3" placeholder="(Auto-Generated)" readonly>
                                        <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i>Admission number will be generated automatically.</div>
                                    </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold small text-muted">First Name</label>
                                            <input type="text" name="firstName" class="form-control" placeholder="e.g. John" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold small text-muted">Last Name</label>
                                            <input type="text" name="lastName" class="form-control" placeholder="e.g. Doe" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold small text-muted">Gender</label>
                                            <select name="gender" class="form-select bg-light border-0">
                                                <option value="Male">Male</option>
                                                <option value="Female">Female</option>
                                                <option value="Other">Other</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold small text-muted">Date of Birth</label>
                                            <input type="date" name="dateOfBirth" class="form-control" required>
                                        </div>
                                        <div class="col-12 mt-4">
                                            <label class="form-label fw-bold small text-muted">Residential Address</label>
                                            <textarea name="address" class="form-control" rows="3" placeholder="Street, City, State..."></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Academic Registration -->
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="p-4 border-bottom d-flex align-items-center gap-3">
                                    <div class="stats-icon bg-primary text-white mb-0" style="width: 32px; height: 32px; font-size: 1rem;">
                                        <i class="bi bi-journal-plus"></i>
                                    </div>
                                    <h5 class="mb-0">Academic Registration</h5>
                                </div>
                                <div class="card-body p-4">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold small text-muted">Assigned Class</label>
                                            <select name="class" class="form-select bg-light border-0" required>
                                                <option value="">Select Class...</option>
                                                <% classes.forEach(c => { %>
                                                    <option value="<%= c._id %>"><%= c.className %> - <%= c.section %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold small text-muted">Admission Status</label>
                                            <select name="status" class="form-select bg-light border-0">
                                                <option value="Active">Active / Registered</option>
                                                <option value="Pending">Pending Approval</option>
                                                <option value="Inactive">On Hold</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="reset" class="btn btn-light px-4 border text-muted">Clear Fields</button>
                                <button type="submit" class="btn btn-primary px-5">Submit Registration</button>
                            </div>
                        </div>

                        <!-- Side Column (Contact & Media) -->
                        <div class="col-lg-4">
                            <div class="card border-0 shadow-sm mb-4 overflow-hidden">
                                <div class="p-4 border-bottom d-flex align-items-center gap-3">
                                    <div class="stats-icon bg-primary text-white mb-0" style="width: 32px; height: 32px; font-size: 1rem;">
                                        <i class="bi bi-camera-fill"></i>
                                    </div>
                                    <h5 class="mb-0">Profile Picture</h5>
                                </div>
                                <div class="card-body p-4 text-center">
                                    <div class="mb-4">
                                        <div class="profile-preview bg-light mx-auto position-relative" style="width: 150px; height: 150px; border-radius: 50%; overflow: hidden; border: 4px solid #fff; box-shadow: var(--shadow-md);">
                                            <img id="avatarPreview" src="/uploads/default-avatar.png" class="w-100 h-100 object-fit-cover">
                                            <div class="upload-overlay w-100 h-100 position-absolute top-0 start-0 d-flex align-items-center justify-content-center bg-dark bg-opacity-50 opacity-0 transition-all cursor-pointer" onclick="document.getElementById('profilePicture').click()">
                                                <i class="bi bi-camera text-white fs-4"></i>
                                            </div>
                                        </div>
                                        <style>
                                            .profile-preview:hover .upload-overlay { opacity: 1; }
                                        </style>
                                    </div>
                                    <input type="file" name="profilePicture" id="profilePicture" class="d-none" accept="image/*" onchange="previewImage(event)">
                                    <button type="button" onclick="document.getElementById('profilePicture').click()" class="btn btn-sm btn-outline-primary rounded-8 px-3">
                                        Choose Image
                                    </button>
                                    <p class="text-muted small mt-3 italic">Max size: 2MB. JPG/PNG supported.</p>
                                </div>
                            </div>

                            <!-- Contact Info -->
                            <div class="card border-0 shadow-sm">
                                <div class="p-4 border-bottom d-flex align-items-center gap-3">
                                    <div class="stats-icon bg-primary text-white mb-0" style="width: 32px; height: 32px; font-size: 1rem;">
                                        <i class="bi bi-telephone-fill"></i>
                                    </div>
                                    <h5 class="mb-0">Contact Details</h5>
                                </div>
                                <div class="card-body p-4">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold small text-muted">Parent/Guardian Email</label>
                                        <input type="email" name="email" class="form-control border-0 bg-light" placeholder="email@guardian.com">
                                    </div>
                                    <div class="mb-0">
                                        <label class="form-label fw-bold small text-muted">Contact Phone Number</label>
                                        <input type="tel" name="phoneNumber" class="form-control border-0 bg-light" placeholder="+254 7xx xxx xxx" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function previewImage(event) {
            const preview = document.getElementById('avatarPreview');
            const file = event.target.files[0];
            const reader = new FileReader();

            reader.onloadend = function() {
                preview.src = reader.result;
            }

            if (file) {
                reader.readAsDataURL(file);
            }
        }
        
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>