<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Exam Results Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Grading & Result Management</h2>
                        <p class="text-muted small mb-0">Record student marks, finalize academic grades, and generate performance reports for <%= exam.examName %>.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary border-0 bg-white shadow-sm" onclick="window.print()">
                            <i class="bi bi-printer me-2"></i>Print Ledger
                        </button>
                        <a href="/exams" class="btn btn-light rounded-12 border px-3">
                            <i class="bi bi-arrow-left me-2"></i>Back
                        </a>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Results Entry Form -->
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm p-4 h-100">
                            <h6 class="mb-4 text-muted small text-uppercase fw-bold"><i class="bi bi-plus-circle-fill me-2"></i>Record New Score</h6>
                            <form action="/exams/<%= exam._id %>/results/add" method="POST">
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Identify Student</label>
                                    <select name="studentId" class="form-select bg-light border-0 py-3" required>
                                        <option value="">Choose Student From Class...</option>
                                        <% students.forEach(stu => { %>
                                            <option value="<%= stu._id %>"><%= stu.firstName %> <%= stu.lastName %> (<%= stu.admissionNumber %>)</option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Marks Obtained (Out of 100)</label>
                                    <input type="number" name="marksObtained" class="form-control bg-light border-0 py-3 font-monospace h4 text-primary" placeholder="e.g. 85" min="0" max="100" required>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Final Evaluation Status</label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check custom-radio flex-fill">
                                            <input class="form-check-input d-none" type="radio" name="status" id="pass" value="Pass" checked>
                                            <label class="form-check-label w-100 p-2 text-center rounded-8 border fw-bold small cursor-pointer" for="pass">PASS</label>
                                        </div>
                                        <div class="form-check custom-radio flex-fill">
                                            <input class="form-check-input d-none" type="radio" name="status" id="fail" value="Fail">
                                            <label class="form-check-label w-100 p-2 text-center rounded-8 border fw-bold small cursor-pointer" for="fail">FAIL</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Evaluator's Remarks</label>
                                    <textarea name="remarks" class="form-control bg-light border-0 py-2" rows="2" placeholder="Teacher's comments..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 py-3 rounded-12 shadow-md fw-bold">Commit Score to Ledger</button>
                            </form>
                        </div>
                    </div>

                    <!-- Recorded Results List -->
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm overflow-hidden h-100 animate-up">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light bg-opacity-50">
                                        <tr>
                                            <th class="ps-4 border-0 text-uppercase small text-muted font-monospace py-3">Student Name</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3">Score</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3 text-center">Status</th>
                                            <th class="pe-4 border-0 text-uppercase small text-muted font-monospace py-3 text-end">Remarks</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (results && results.length > 0) { %>
                                            <% results.forEach(res => { %>
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="fw-bold text-main small"><%= res.student ? res.student.firstName + ' ' + res.student.lastName : 'N/A' %></div>
                                                        <div class="small text-muted italic">ID: <%= res.student ? res.student.admissionNumber : 'N/A' %></div>
                                                    </td>
                                                    <td class="py-3">
                                                        <div class="h6 mb-0 fw-bold text-primary font-monospace"><%= res.marksObtained %> / 100</div>
                                                    </td>
                                                    <td class="py-3 text-center">
                                                        <% if (res.status === 'Pass') { %>
                                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">PASS</span>
                                                        <% } else { %>
                                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">FAIL</span>
                                                        <% } %>
                                                    </td>
                                                    <td class="pe-4 py-3 text-end">
                                                        <div class="small text-muted italic"><%= res.remarks || 'No remarks recorded.' %></div>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="4" class="text-center py-5">
                                                    <div class="text-muted opacity-50 d-flex flex-column align-items-center">
                                                        <i class="bi bi-mortarboard display-3 mb-3"></i>
                                                        <h5 class="mb-1">No Results Recorded</h5>
                                                        <p class="small mb-0">Academic scores for this examination have not been committed yet.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>
