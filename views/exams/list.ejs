<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Exams List Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Examination Hub</h2>
                        <p class="text-muted small mb-0">Schedule assessments, manage invigilation, and record academic performance.</p>
                    </div>
                    <a href="/exams/add" class="btn btn-primary">
                        <i class="bi bi-calendar-plus me-2"></i>Schedule Exam
                    </a>
                </div>

                <!-- Exams Table -->
                <div class="card border-0 shadow-sm overflow-hidden animate-up">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 border-0 text-uppercase small text-muted font-monospace py-3">Examination Name</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Class / Subject</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Exam Date</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Type</th>
                                    <th class="pe-4 border-0 text-uppercase small text-muted font-monospace py-3 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (exams && exams.length > 0) { %>
                                    <% exams.forEach(exam => { %>
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="fw-bold text-main"><%= exam.examName %></div>
                                                <div class="small text-muted italic">Invigilator: <%= exam.invigilator ? exam.invigilator.firstName : 'Unassigned' %></div>
                                            </td>
                                            <td class="py-3">
                                                <div class="small fw-bold text-main"><%= exam.class ? exam.class.className : 'N/A' %></div>
                                                <div class="small text-muted fw-medium"><%= exam.subject ? exam.subject.subjectName : 'General' %></div>
                                            </td>
                                            <td class="py-3">
                                                <div class="small text-muted fw-bold">
                                                    <i class="bi bi-calendar3 me-2"></i><%= new Date(exam.date).toLocaleDateString('en-GB') %>
                                                </div>
                                            </td>
                                            <td class="py-3">
                                                <span class="badge bg-primary bg-opacity-10 text-primary px-3 rounded-pill" style="font-size: 10px;">
                                                    <%= exam.examType.toUpperCase() %>
                                                </span>
                                            </td>
                                            <td class="pe-4 py-3 text-end">
                                                <div class="dropdown">
                                                    <i class="bi bi-three-dots-vertical text-muted cursor-pointer" data-bs-toggle="dropdown"></i>
                                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 rounded-12">
                                                        <li><a class="dropdown-item p-2 rounded-8" href="/exams/<%= exam._id %>"><i class="bi bi-eye me-2"></i> View Details</a></li>
                                                        <li><a class="dropdown-item p-2 rounded-8" href="/exams/<%= exam._id %>/results"><i class="bi bi-award me-2"></i> Results</a></li>
                                                        <li><a class="dropdown-item p-2 rounded-8" href="/exams/<%= exam._id %>/edit"><i class="bi bi-pencil me-2"></i> Edit</a></li>
                                                        <li><hr class="dropdown-divider"></li>
                                                        <li><a class="dropdown-item p-2 rounded-8 text-danger" href="/exams/<%= exam._id %>/delete" onclick="return confirm('Delete this examination?')"><i class="bi bi-trash me-2"></i> Delete</a></li>
                                                    </ul>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="text-muted opacity-50 d-flex flex-column align-items-center">
                                                <i class="bi bi-journal-x display-3 mb-3"></i>
                                                <h5 class="mb-1">No Exams Found</h5>
                                                <p class="small mb-0">No examinations scheduled for the current academic session.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>