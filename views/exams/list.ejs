<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2>Exams</h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/exams/add" class="btn btn-primary"><i class="fas fa-plus-circle me-2"></i>Schedule Exam</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <% if (exams && exams.length) { %>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Class</th>
                        <th>Subject</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% exams.forEach(e => { %>
                        <tr>
                            <td><%= e.examName %></td>
                            <td><%= e.examType %></td>
                            <td><%= e.class ? e.class.className + ' ' + e.class.section : '' %></td>
                            <td><%= e.subject ? e.subject.name : '' %></td>
                            <td><%= e.date.toLocaleDateString() %></td>
                            <td>
                                <a href="/exams/<%= e._id %>" class="btn btn-sm btn-info">View</a>
                                <a href="/exams/<%= e._id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/exams/<%= e._id %>/results" class="btn btn-sm btn-success">Results</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p class="text-muted">No exams scheduled.</p>
        <% } %>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>