<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2><%= exam.examName %></h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/exams" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Type:</strong> <%= exam.examType %></p>
        <p><strong>Class:</strong> <%= exam.class ? exam.class.className + ' ' + exam.class.section : '' %></p>
        <p><strong>Subject:</strong> <%= exam.subject ? exam.subject.name : '' %></p>
        <p><strong>Date:</strong> <%= exam.date.toLocaleDateString() %></p>
        <p><strong>Time:</strong> <%= exam.startTime || '' %> - <%= exam.endTime || '' %></p>
        <p><strong>Total Marks:</strong> <%= exam.totalMarks %></p>
        <p><strong>Passing Marks:</strong> <%= exam.passingMarks || '-' %></p>
        <p><strong>Room:</strong> <%= exam.room || '-' %></p>
        <p><strong>Invigilator:</strong> <%= exam.invigilator ? exam.invigilator.firstName + ' ' + exam.invigilator.lastName : '-' %></p>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>