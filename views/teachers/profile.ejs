<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Faculty Profile Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Faculty Member Profile</h2>
                        <p class="text-muted small mb-0">Detailed information and departmental status for the assigned instructor.</p>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Profile Card -->
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm p-4 text-center mb-4">
                            <div class="profile-avatar mb-3 text-center position-relative mx-auto">
                                <img src="/uploads/<%= teacher.profilePicture || 'default-avatar.png' %>" 
                                     alt="<%= teacher.firstName %>" 
                                     class="rounded-circle shadow-md border"
                                     style="width: 140px; height: 140px; object-fit: cover; border-width: 5px !important; border-color: #fff !important;">
                            </div>
                            <h4 class="mb-1 text-main fw-bold"><%= teacher.firstName %> <%= teacher.lastName %></h4>
                            <div class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 mb-4 small fw-bold">
                                ID: <%= teacher.employeeId %> / <%= teacher.department || 'General' %>
                            </div>
                            
                            <div class="row g-2">
                                <div class="col-12">
                                    <a href="/teachers/<%= teacher._id %>/edit" class="btn btn-primary w-100 rounded-12 shadow-sm py-2 fw-bold">
                                        <i class="bi bi-pencil-square me-2"></i>Edit Faculty Record
                                    </a>
                                </div>
                                <div class="col-12 mt-2">
                                    <a href="/teachers" class="btn btn-light w-100 rounded-12 border py-2 small fw-bold text-muted">
                                        <i class="bi bi-arrow-left me-2"></i>Back to Directory
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Stats Card -->
                        <div class="card border-0 shadow-sm p-4 bg-primary bg-opacity-10">
                            <h6 class="mb-4 text-muted small text-uppercase fw-bold"><i class="bi bi-person-badge me-2"></i>Employment Status</h6>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="small text-muted fw-medium">Joining Date</span>
                                <span class="small text-main fw-bold"><%= teacher.joiningDate ? new Date(teacher.joiningDate).toLocaleDateString() : 'N/A' %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="small text-muted fw-medium">Status</span>
                                <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25">ACTIVE</span>
                            </div>
                        </div>
                    </div>

                    <!-- Details Tab -->
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm p-4 h-100">
                            <ul class="nav nav-tabs border-0 gap-4 mb-5" id="facultyTab" role="tablist">
                                <li class="nav-item">
                                    <button class="nav-link active border-0 bg-transparent py-2 px-0 fw-bold small text-uppercase" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab">Contact & Personal</button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link border-0 bg-transparent py-2 px-0 fw-bold small text-uppercase" id="subjects-tab" data-bs-toggle="tab" data-bs-target="#subjects" type="button" role="tab">Assigned Subjects</button>
                                </li>
                            </ul>

                            <div class="tab-content">
                                <div class="tab-pane fade show active" id="contact" role="tabpanel">
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-16">
                                                <div class="text-muted small mb-1 fw-bold">Official Email</div>
                                                <div class="text-main fw-medium"><%= teacher.email %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-16">
                                                <div class="text-muted small mb-1 fw-bold">Contact Number</div>
                                                <div class="text-main fw-medium"><%= teacher.phone || teacher.phoneNumber || 'N/A' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-16">
                                                <div class="text-muted small mb-1 fw-bold">Qualification</div>
                                                <div class="text-main fw-medium text-capitalize"><%= teacher.qualification || 'N/A' %></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 bg-light rounded-16">
                                                <div class="text-muted small mb-1 fw-bold">Address</div>
                                                <div class="text-main fw-medium"><%= teacher.address || 'N/A' %></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="tab-pane fade" id="subjects" role="tabpanel">
                                    <div class="d-grid gap-3">
                                        <% if (teacher.subjects && teacher.subjects.length > 0) { %>
                                            <% teacher.subjects.forEach(sub => { %>
                                                <div class="p-3 border rounded-16 d-flex justify-content-between align-items-center">
                                                    <div class="d-flex align-items-center gap-3">
                                                        <div class="stats-icon bg-info bg-opacity-10 text-info mb-0" style="width: 40px; height: 40px;">
                                                            <i class="bi bi-book"></i>
                                                        </div>
                                                        <div class="fw-bold text-main"><%= sub.subjectName || sub %></div>
                                                    </div>
                                                    <span class="badge bg-light text-muted border px-3">TERM I/II/III</span>
                                                </div>
                                            <% }) %>
                                        <% } else { %>
                                            <div class="text-center py-5 opacity-25">
                                                <i class="bi bi-journal-x display-3"></i>
                                                <p class="mt-2 fw-medium">No Subjects Assigned Yet</p>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>
