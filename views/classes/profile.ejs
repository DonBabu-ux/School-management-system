<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Classroom Detail Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Classroom Insights: <%= cls.className %> - <%= cls.section %></h2>
                        <p class="text-muted small mb-0">Overview of academic faculty, student enrollment, and subject distribution.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/classes/<%= cls._id %>/edit" class="btn btn-primary rounded-12 shadow-md">
                            <i class="bi bi-pencil-square me-2"></i>Edit Configuration
                        </a>
                        <a href="/classes" class="btn btn-light rounded-12 border px-3 fw-bold">
                            <i class="bi bi-arrow-left me-2"></i>Back to Hub
                        </a>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-md-4">
                        <div class="card p-4 border-0 shadow-sm glass h-100">
                            <h6 class="text-muted small fw-bold text-uppercase mb-3">Enrolled Students</h6>
                            <h2 class="mb-0 text-primary fw-bold font-monospace"><%= cls.students ? cls.students.length : 0 %></h2>
                            <div class="progress mt-3 bg-light" style="height: 6px;">
                                <div class="progress-bar bg-primary" role="progressbar" style="width: <%= (cls.students ? cls.students.length : 0) / 40 * 100 %>%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card p-4 border-0 shadow-sm glass h-100">
                            <h6 class="text-muted small fw-bold text-uppercase mb-3">Principal Teacher</h6>
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-sm rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                    <i class="bi bi-person-workspace text-main"></i>
                                </div>
                                <div class="fw-bold text-main small"><%= cls.classTeacher ? cls.classTeacher.firstName + ' ' + cls.classTeacher.lastName : 'NOT ASSIGNED' %></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card p-4 border-0 shadow-sm glass h-100">
                            <h6 class="text-muted small fw-bold text-uppercase mb-3">Assigned Subjects</h6>
                            <h2 class="mb-0 text-main fw-bold font-monospace"><%= cls.subjects ? cls.subjects.length : 0 %></h2>
                            <p class="small text-muted mb-0 italic mt-2">Core Curriculum</p>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Subjects Table -->
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm overflow-hidden animate-up">
                            <div class="p-4 border-bottom bg-white">
                                <h6 class="mb-0 text-main fw-bold">Academic Subjects & Instructors</h6>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light bg-opacity-50">
                                        <tr>
                                            <th class="ps-4 border-0 text-uppercase small text-muted font-monospace py-3">Subject Name</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3">Assigned Faculty</th>
                                            <th class="pe-4 border-0 text-uppercase small text-muted font-monospace py-3 text-end">Schedule Area</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (cls.subjects && cls.subjects.length > 0) { %>
                                            <% cls.subjects.forEach(s => { %>
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="fw-bold text-main small"><%= s.subject ? s.subject.subjectName || s.subject.name : 'Unknown' %></div>
                                                    </td>
                                                    <td class="py-3">
                                                        <div class="small fw-medium text-muted">
                                                            <%= s.teacher ? s.teacher.firstName + ' ' + s.teacher.lastName : 'NOT ASSIGNED' %>
                                                        </div>
                                                    </td>
                                                    <td class="pe-4 py-3 text-end">
                                                        <span class="badge bg-light text-muted border px-2 py-1" style="font-size: 9px;">CORE SESSION</span>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="3" class="text-center py-5">
                                                    <div class="text-muted opacity-25 d-flex flex-column align-items-center">
                                                        <i class="bi bi-journal-x display-3 mb-3"></i>
                                                        <h5 class="mb-1">No Subjects Registered</h5>
                                                        <p class="small mb-0">Curriculum for this class stream has not been configured yet.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Enrolled Students (Quick List) -->
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm p-4 h-100">
                            <h6 class="mb-4 text-muted small text-uppercase fw-bold"><i class="bi bi-people-fill me-2"></i>Class Roll Call</h6>
                            <div class="student-list overflow-auto" style="max-height: 400px;">
                                <% if (cls.students && cls.students.length > 0) { %>
                                    <% cls.students.forEach(student => { %>
                                        <div class="d-flex align-items-center gap-3 mb-3 p-2 bg-light rounded-12 border border-transparent hover-border-primary transition-all">
                                            <div class="avatar-xs rounded-circle overflow-hidden shadow-sm" style="width: 32px; height: 32px;">
                                                <img src="/uploads/<%= student.profilePicture || 'default-avatar.png' %>" class="w-100 h-100 object-fit-cover">
                                            </div>
                                            <div class="overflow-hidden">
                                                <div class="small fw-bold text-main text-truncate"><%= student.firstName %> <%= student.lastName %></div>
                                                <div class="text-muted" style="font-size: 9px;"><%= student.admissionNumber %></div>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="text-center py-5 opacity-25">
                                        <i class="bi bi-person-slash display-4"></i>
                                        <p class="small mt-2">Zero enrollment</p>
                                    </div>
                                <% } %>
                            </div>
                            <div class="text-center mt-4 pt-3 border-top">
                                <a href="/students/add?classId=<%= cls._id %>" class="btn btn-sm btn-outline-primary border-0 bg-primary bg-opacity-10 rounded-pill px-3">
                                    <i class="bi bi-plus-lg me-1"></i>Enroll New Student
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>