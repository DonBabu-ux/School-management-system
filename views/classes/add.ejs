<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Add Class Form Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Establish New Class</h2>
                        <p class="text-muted small mb-0">Define classroom parameters, sections, and assign class leadership.</p>
                    </div>
                    <a href="/classes" class="btn btn-outline-secondary border-0 bg-white shadow-sm">
                        <i class="bi bi-arrow-left me-2"></i>Back to Classes
                    </a>
                </div>

                <% if (error) { %>
                    <div class="alert alert-danger mb-4 shadow-sm border-0 d-flex align-items-center rounded-16 p-3 animate-up">
                        <i class="bi bi-exclamation-triangle-fill me-3 fs-3"></i>
                        <div class="small fw-medium">Oops! <%= error %></div>
                    </div>
                <% } %>

                <form action="/classes/add" method="POST">
                    <div class="row g-4">
                        <!-- Main Class Details -->
                        <div class="col-lg-8">
                            <div class="card border-0 shadow-sm p-4 mb-4">
                                <h6 class="mb-4 text-muted small text-uppercase fw-bold"><i class="bi bi-card-list me-2"></i>Class Definition</h6>
                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Class Level / Name</label>
                                        <input type="text" name="className" class="form-control bg-light border-0 py-3" placeholder="e.g. Grade 1 or Primary 1" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Section / Stream</label>
                                        <input type="text" name="section" class="form-control bg-light border-0 py-3" placeholder="e.g. Blue, Alpha, or Section A" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Room Number</label>
                                        <input type="text" name="roomNumber" class="form-control bg-light border-0 py-3" placeholder="Block B - 02">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Academic Cycle</label>
                                        <select name="academicYear" class="form-select bg-light border-0 py-3" required>
                                            <option value="2024-2025">Year 2024-2025</option>
                                            <option value="2025-2026">Year 2025-2026</option>
                                            <option value="2026-2027">Year 2026-2027</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Teacher Leadership -->
                            <div class="card border-0 shadow-sm p-4 mb-4">
                                <h6 class="mb-4 text-muted small text-uppercase fw-bold"><i class="bi bi-shield-check me-2"></i>Leadership & Mentorship</h6>
                                <div class="mb-0">
                                    <label class="form-label fw-bold small text-muted">Assigned Class Teacher</label>
                                    <select name="classTeacher" class="form-select bg-light border-0 py-3" required>
                                        <option value="">Select Class Mentor...</option>
                                        <% teachers.forEach(t => { %>
                                            <option value="<%= t._id %>"><%= t.firstName %> <%= t.lastName %> (<%= t.employeeId %>)</option>
                                        <% }) %>
                                    </select>
                                    <p class="small text-muted mt-3 italic mb-0">The class teacher will be responsible for attendance and overall students behavior records for this class.</p>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary px-5 py-3 rounded-12 shadow-md fw-bold w-100">
                                    Initialize New Class
                                </button>
                            </div>
                        </div>

                        <!-- Side Sidebar (Capacity & Info) -->
                        <div class="col-lg-4">
                            <div class="card border-0 shadow-sm p-4 mb-4 text-center">
                                <h6 class="mb-4 text-muted small text-uppercase fw-bold">Enrollment Capacity</h6>
                                <div class="mx-auto bg-primary bg-opacity-10 rounded-circle mb-4 d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                    <i class="bi bi-people-fill text-primary display-6"></i>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted d-block">Maximum Students</label>
                                    <input type="number" name="capacity" class="form-control border-0 bg-light py-3 text-center fw-bold text-main" value="40" required>
                                </div>
                                <p class="small text-muted italic">Recommended capacity per stream for balanced student-teacher ratio is 35-45 students.</p>
                            </div>

                            <div class="card border-0 shadow-sm p-4 bg-primary text-white" style="background: linear-gradient(135deg, #a5b4fc 0%, #6366f1 100%);">
                                <h6 class="mb-3 small text-uppercase fw-bold text-white-50">Quick Fact</h6>
                                <p class="small mb-0 fw-medium">EduSmart is currently hosting over 1,200 active students across 30 different streams. Quality management starts with organized classroom hierarchies.</p>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>