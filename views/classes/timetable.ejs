<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Timetable Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Weekly Academic Schedule</h2>
                        <p class="text-muted small mb-0">Class: <%= cls.className %> - <%= cls.section %></p>
                    </div>
                    <a href="/classes/<%= cls._id %>" class="btn btn-outline-secondary border-0 bg-white shadow-sm">
                        <i class="bi bi-arrow-left me-2"></i>Class Details
                    </a>
                </div>

                <div class="row g-4">
                    <!-- Schedule Table -->
                    <div class="col-lg-12">
                        <div class="card border-0 shadow-sm overflow-hidden anim-up">
                            <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center">
                                <h6 class="mb-0 text-main fw-bold"><i class="bi bi-calendar-event me-2"></i>Curriculum Timetable</h6>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3">Active Schedule</span>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light bg-opacity-50">
                                        <tr>
                                            <th class="ps-4 border-0 text-uppercase small text-muted font-monospace py-3" style="width: 250px;">Subject / Module</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3">Faculty / Educator</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3">Time / Period</th>
                                            <th class="pe-4 border-0 text-uppercase small text-muted font-monospace py-3 text-end">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (cls.subjects && cls.subjects.length > 0) { %>
                                            <% cls.subjects.forEach(s => { %>
                                                <tr>
                                                    <td class="ps-4 py-4">
                                                        <div class="d-flex align-items-center gap-3">
                                                            <div class="stats-icon bg-primary bg-opacity-10 text-primary mb-0" style="width: 42px; height: 42px;">
                                                                <i class="bi bi-book"></i>
                                                            </div>
                                                            <div>
                                                                <div class="fw-bold text-main small"><%= s.subject ? s.subject.name : 'Unknown Subject' %></div>
                                                                <div class="text-muted tiny"><%= s.subject ? s.subject.code : 'No code' %></div>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td class="py-4">
                                                        <div class="d-flex align-items-center gap-2">
                                                            <img src="/uploads/<%= s.teacher ? s.teacher.profilePicture : 'default-avatar.png' %>" 
                                                                 class="rounded-circle" style="width: 24px; height: 24px; object-fit: cover;">
                                                            <span class="small fw-medium"><%= s.teacher ? s.teacher.firstName + ' ' + s.teacher.lastName : 'Unassigned' %></span>
                                                        </div>
                                                    </td>
                                                    <td class="py-4">
                                                        <div class="badge bg-light text-primary border py-2 px-3 rounded-8 small">
                                                            <i class="bi bi-clock me-2"></i><%= s.schedule || 'TBA' %>
                                                        </div>
                                                    </td>
                                                    <td class="pe-4 py-4 text-end">
                                                        <button class="btn btn-icon btn-light border p-1 rounded-8"><i class="bi bi-pencil-square text-muted"></i></button>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="4" class="text-center py-5">
                                                    <div class="opacity-25">
                                                        <i class="bi bi-calendar-x display-4"></i>
                                                        <p class="mt-3 fw-bold">No timetable entries found for this class.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>
