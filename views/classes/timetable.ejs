<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2>Timetable - <%= classItem.className %> <%= classItem.section %></h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/classes" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <% if (classItem.subjects && classItem.subjects.length) { %>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Subject</th>
                        <th>Teacher</th>
                        <th>Schedule</th>
                    </tr>
                </thead>
                <tbody>
                    <% classItem.subjects.forEach(s => { %>
                        <tr>
                            <td><%= s.subject ? s.subject.name : '' %></td>
                            <td><%= s.teacher ? s.teacher.firstName + ' ' + s.teacher.lastName : '' %></td>
                            <td><%= s.schedule || '-' %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p class="text-muted">No subjects/timetable available.</p>
        <% } %>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>
