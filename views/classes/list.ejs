<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2>Classes</h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/classes/add" class="btn btn-primary">
            <i class="fas fa-plus-circle me-2"></i>Add New Class
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Class Name</th>
                        <th>Section</th>
                        <th>Class Teacher</th>
                        <th>Academic Year</th>
                        <th>Capacity</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% classes.forEach(cls => { %>
                        <tr>
                            <td><%= cls.className %></td>
                            <td><%= cls.section || '-' %></td>
                            <td>
                                <% if (cls.classTeacher) { %>
                                    <%= cls.classTeacher.firstName %> <%= cls.classTeacher.lastName %>
                                <% } else { %>
                                    Not Assigned
                                <% } %>
                            </td>
                            <td><%= cls.academicYear %></td>
                            <td><%= cls.capacity || '-' %></td>
                            <td>
                                <a href="/classes/<%= cls._id %>" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="/classes/<%= cls._id %>/edit" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="/classes/<%= cls._id %>/timetable" class="btn btn-sm btn-success">
                                    <i class="fas fa-calendar-alt"></i>
                                </a>
                                <a href="/classes/<%= cls._id %>/delete" class="btn btn-sm btn-danger" onclick="return confirm('Delete this class?');">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>