<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Recovery | EduSmart Support</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main flex-center min-vh-100">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="card border-0 shadow-lg p-5" style="border-radius: 40px;">
                    <div class="text-center mb-5">
                        <div class="stats-icon bg-primary bg-opacity-10 text-primary mx-auto mb-4" style="width: 72px; height: 72px;">
                            <i class="bi bi-shield-lock-fill fs-2"></i>
                        </div>
                        <h2 class="fw-bold text-main font-outfit">Recovery Request</h2>
                        <p class="text-muted small">Submit your institutional credentials for account restoration.</p>
                    </div>

                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger bg-danger bg-opacity-10 border-danger border-opacity-25 text-danger rounded-16 small fw-bold mb-4">
                            <i class="bi bi-x-circle-fill me-2"></i><%= error %>
                        </div>
                    <% } %>
                    <% if (typeof success !== 'undefined' && success) { %>
                        <div class="alert alert-success bg-success bg-opacity-10 border-success border-opacity-25 text-success rounded-16 small fw-bold mb-4">
                            <i class="bi bi-check-circle-fill me-2"></i><%= success %>
                        </div>
                    <% } %>

                    <form action="/auth/forgot-password" method="POST">
                        <div class="mb-3">
                            <label class="tiny fw-bold text-muted mb-2 text-uppercase">Institutional Email</label>
                            <input type="email" name="contactEmail" class="form-control bg-light border-0 py-3 px-4 rounded-16" placeholder="e.g. user@edu.ac.ke" required>
                        </div>
                        <div class="mb-3">
                            <label class="tiny fw-bold text-muted mb-2 text-uppercase">Claimed Credentials ID</label>
                            <input type="text" name="credentialId" class="form-control bg-light border-0 py-3 px-4 rounded-16" placeholder="e.g. ST004 or TCH001" required>
                        </div>
                        <div class="mb-4">
                            <label class="tiny fw-bold text-muted mb-2 text-uppercase">Problem Description</label>
                            <textarea name="description" class="form-control bg-light border-0 py-3 px-4 rounded-16" rows="3" placeholder="Explain the access issue..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-16 shadow-md fw-bold">Submit Support Ticket</button>
                    </form>

                    <div class="mt-5 text-center">
                        <a href="/auth/login" class="text-muted text-decoration-none small fw-bold"><i class="bi bi-arrow-left me-1"></i> Return to Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
