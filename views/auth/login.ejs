<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            background: radial-gradient(circle at top right, #6366f1 0%, #4f46e5 20%, #0f172a 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            padding: 20px;
        }
        .login-container {
            width: 100%;
            max-width: 440px;
        }
        .login-card {
            border-radius: 24px;
            padding: 48px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .brand-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #a5b4fc 0%, #6366f1 100%);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            box-shadow: 0 8px 16px rgba(99, 102, 241, 0.4);
        }
    </style>
</head>
<body>
    <div class="login-container animate-up">
        <div class="login-card glass bg-white p-5">
            <div class="text-center mb-5">
                <div class="brand-icon mx-auto">
                    <i class="bi bi-mortarboard-fill fs-2 text-white"></i>
                </div>
                <h2 class="h3 fw-bold text-main mb-1">Welcome Back</h2>
                <p class="text-muted small">Access your institutional dashboard and reports.</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-danger border-0 shadow-sm rounded-12 p-3 d-flex align-items-center mb-4">
                    <i class="bi bi-exclamation-circle-fill me-2"></i>
                    <div class="small fw-medium"><%= error %></div>
                </div>
            <% } %>

            <form action="/auth/login" method="POST">
                <div class="mb-4">
                    <label class="form-label fw-bold small text-muted">System ID / Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-person-badge"></i></span>
                        <input type="text" name="loginId" class="form-control bg-light border-0 py-2 shadow-none" placeholder="e.g. STU001 or Admin Email" required>
                    </div>
                </div>

                <div class="mb-5">
                    <div class="d-flex justify-content-between">
                        <label class="form-label fw-bold small text-muted">Password</label>
                        <a href="/auth/forgot-password" class="small text-primary text-decoration-none fw-bold">Forgot?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-lock"></i></span>
                        <input type="password" name="password" class="form-control bg-light border-0 py-2 shadow-none" placeholder="••••••••" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 rounded-12 shadow-md fw-bold">
                    Secure Login
                </button>
            </form>

            <div class="mt-5 text-center text-muted small fw-medium">
                Difficulty logging in? Visit the Admin Office.
            </div>
        </div>
        
        <div class="text-center mt-5 text-white-50 small">
            &copy; 2024 EduSmart Institutional Solutions. All rights reserved.
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>