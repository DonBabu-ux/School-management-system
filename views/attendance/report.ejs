<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | EduSmart
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-main">
    <div class="dashboard-wrapper">
        <%- include('../layouts/sidebar', { currentUrl: '/attendance' }) %>
            <main class="main-content">
                <%- include('../layouts/header') %>
                    <div class="animate-up">
                        <h2 class="h3 fw-bold text-main mb-4">Attendance Report</h2>
                        <div class="card border-0 shadow-sm p-4 rounded-40">
                            <!-- Basic Attendance placeholder -->
                            <p class="text-muted">Attendance oversight for <%= title %> records.</p>
                        </div>
                    </div>
            </main>
    </div>
</body>

</html>