<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .vault-card {
            background-color: #1a1b1e;
            color: white;
            border-radius: 20px;
        }
        .credential-grid {
            border: 1px solid rgba(255,255,255,0.1);
        }
    </style>
</head>
<body class="bg-main h-100">
    <div class="dashboard-wrapper">
        <%- include('../layouts/sidebar') %>

        <main class="main-content">
            <%- include('../layouts/header') %>

            <div class="animate-up mb-4 d-flex justify-content-between align-items-center mt-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-dark bg-opacity-10 text-dark rounded-circle p-3 shadow-sm border border-light">
                        <i class="bi bi-box-seam-fill fs-3 mb-0"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0">The Pigeon Hole (Vault)</h3>
                        <p class="text-muted small mb-0 fw-bold">Highly sensitive: Plaintext passwords for initially onboarded users.</p>
                    </div>
                </div>
                <div class="text-end">
                    <a href="/dashboard/pigeon/lock" class="btn btn-outline-danger shadow-sm fw-bold">
                        <i class="bi bi-lock-fill me-2"></i>Lock Vault
                    </a>
                </div>
            </div>

            <!-- Management Section -->
            <div class="row g-4 animate-up mb-5">
                <div class="col-lg-6">
                    <div class="card p-4 border-warning border-2 border-opacity-50 shadow-sm" style="border-radius: 16px;">
                        <h5 class="fw-bold text-dark d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-key-fill text-warning fs-3"></i> Vault Secret Key
                        </h5>
                        
                        <div class="p-3 bg-light rounded-12 mb-3 border d-flex justify-content-between align-items-center">
                            <div>
                                <span class="small fw-bold text-muted text-uppercase mb-1 d-block">Current Vault Key</span>
                                <span class="fs-4 fw-black font-monospace letter-spacing-2 text-dark user-select-all" id="currentKey"><%= currentSecret %></span>
                            </div>
                            <button onclick="navigator.clipboard.writeText('<%= currentSecret %>'); alert('Secret copied to clipboard!');" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                        
                        <form action="/dashboard/pigeon/reset" method="POST" class="mt-4">
                            <label class="small text-muted fw-bold mb-2">Change Secret Key</label>
                            <div class="input-group">
                                <input type="text" name="newSecret" class="form-control bg-light border-0 py-2 rounded-start-12" placeholder="e.g. D1C70A" required minlength="4">
                                <button type="submit" class="btn btn-dark rounded-end-12 fw-bold px-4">Update Key</button>
                            </div>
                        </form>
                    </div>
                </div>
                
                <div class="col-lg-6">
                    <div class="card p-4 h-100 bg-dark text-white shadow-lg" style="border-radius: 16px;">
                        <div class="d-flex mb-3 gap-3">
                            <i class="bi bi-info-circle display-4 text-white opacity-50"></i>
                            <div>
                                <h5 class="fw-bold mb-1">What is this?</h5>
                                <p class="small text-white-50 lh-lg mb-0 text-wrap">
                                    When you add a new Student, Teacher, or User, the system drops their autogenerated username/ID and password into this vault. Direct them here so you can securely hand over their credentials. Passwords are officially hashed and obscured everywhere else in the database.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Credentials Table -->
            <div class="card vault-card shadow-lg p-0 border-0 overflow-hidden animate-up">
                <div class="p-4 border-bottom border-secondary border-opacity-25 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">Captured Credentials</h5>
                    <span class="badge bg-light text-dark bg-opacity-10 py-2 font-monospace px-3"><%= credentials.length %> Rows</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0 align-middle">
                        <thead style="background: rgba(255,255,255,0.05);">
                            <tr>
                                <th class="py-3 ps-4 border-0 small text-uppercase text-white-50">Name</th>
                                <th class="py-3 border-0 small text-uppercase text-white-50">Role</th>
                                <th class="py-3 border-0 small text-uppercase text-white-50">Reg No / ID</th>
                                <th class="py-3 border-0 small text-uppercase text-white-50">Password</th>
                                <th class="py-3 border-0 small text-uppercase text-white-50">Generated On</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (credentials && credentials.length > 0) { %>
                                <% credentials.forEach(cred => { %>
                                    <tr>
                                        <td class="ps-4 py-3 fw-bold text-white"><%= cred.ownerName %></td>
                                        <td class="py-3">
                                            <span class="badge bg-<%= cred.role === 'teacher' ? 'warning' : 'info' %> text-dark">
                                                <%= cred.role.toUpperCase() %>
                                            </span>
                                        </td>
                                        <td class="py-3 font-monospace text-info fw-bold"><%= cred.username %></td>
                                        <td class="py-3">
                                            <div class="d-inline-flex border border-secondary border-opacity-50 align-items-center rounded bg-dark px-3 py-1 text-warning fw-black font-monospace user-select-all" style="letter-spacing: 1px;">
                                                <%= cred.plainPassword %>
                                            </div>
                                        </td>
                                        <td class="py-3 small text-white-50"><%= new Date(cred.createdAt).toLocaleDateString() %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="py-5 text-center text-white-50">
                                        <i class="bi bi-inbox display-4 d-block mb-3 opacity-25"></i>
                                        No credentials have been generated and captured yet.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>
