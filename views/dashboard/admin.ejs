<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Dashboard Content -->
            <div class="animate-up">
                <div class="row align-items-center mb-5">
                    <div class="col">
                        <h2 class="h3 text-main mb-1">Hello, <%= user.firstName %> 👋</h2>
                        <p class="text-muted small mb-0">Today is <%= moment().format('dddd, MMMM Do YYYY') %></p>
                    </div>
                </div>

                <!-- Stats Cards Row -->
                <div class="row g-4 mb-5">
                    <div class="col-md-3">
                        <div class="card p-4 h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #a5b4fc 0%, #6366f1 100%);">
                            <div class="d-flex justify-content-between align-items-center mb-0">
                                <div class="stats-icon bg-white bg-opacity-25 text-white mb-0">
                                    <i class="bi bi-people-fill"></i>
                                </div>
                                <div class="dropdown">
                                    <i class="bi bi-three-dots-vertical text-white cursor-pointer" data-bs-toggle="dropdown"></i>
                                    <ul class="dropdown-menu border-0 shadow-md">
                                        <li><a class="dropdown-item py-1 px-3 small" href="/students/add">Add Student</a></li>
                                        <li><a class="dropdown-item py-1 px-3 small" href="/students">View List</a></li>
                                    </ul>
                                </div>
                            </div>
                            <div class="mt-4">
                                <h2 class="text-white display-6 fw-bold mb-1"><%= stats.totalStudents %></h2>
                                <p class="text-white text-opacity-75 small mb-0 fw-medium">Total active students</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card p-4 h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #86efac 0%, #10b981 100%);">
                            <div class="d-flex justify-content-between align-items-center mb-0">
                                <div class="stats-icon bg-white bg-opacity-25 text-white mb-0">
                                    <i class="bi bi-person-badge-fill"></i>
                                </div>
                                <div class="dropdown">
                                    <i class="bi bi-three-dots-vertical text-white cursor-pointer" data-bs-toggle="dropdown"></i>
                                    <ul class="dropdown-menu border-0 shadow-md">
                                        <li><a class="dropdown-item py-1 px-3 small" href="/teachers/add">Add Teacher</a></li>
                                        <li><a class="dropdown-item py-1 px-3 small" href="/teachers">All Teachers</a></li>
                                    </ul>
                                </div>
                            </div>
                            <div class="mt-4">
                                <h2 class="text-white display-6 fw-bold mb-1"><%= stats.totalTeachers %></h2>
                                <p class="text-white text-opacity-75 small mb-0 fw-medium">Certified instructors</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card p-4 h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #fde68a 0%, #f59e0b 100%);">
                            <div class="d-flex justify-content-between align-items-center mb-0">
                                <div class="stats-icon bg-white bg-opacity-25 text-white mb-0">
                                    <i class="bi bi-journal-text"></i>
                                </div>
                                <div class="dropdown">
                                    <i class="bi bi-three-dots-vertical text-white cursor-pointer" data-bs-toggle="dropdown"></i>
                                    <ul class="dropdown-menu border-0 shadow-md">
                                        <li><a class="dropdown-item py-1 px-3 small" href="/classes/add">Create Class</a></li>
                                        <li><a class="dropdown-item py-1 px-3 small" href="/classes">Active Classes</a></li>
                                    </ul>
                                </div>
                            </div>
                            <div class="mt-4">
                                <h2 class="text-white display-6 fw-bold mb-1"><%= stats.totalClasses %></h2>
                                <p class="text-white text-opacity-75 small mb-0 fw-medium">Standard curriculum classes</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card p-4 h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #7dd3fc 0%, #0ea5e9 100%);">
                            <div class="d-flex justify-content-between align-items-center mb-0">
                                <div class="stats-icon bg-white bg-opacity-25 text-white mb-0">
                                    <i class="bi bi-wallet2"></i>
                                </div>
                                <div class="dropdown">
                                    <i class="bi bi-three-dots-vertical text-white cursor-pointer" data-bs-toggle="dropdown"></i>
                                    <ul class="dropdown-menu border-0 shadow-md">
                                        <li><a class="dropdown-item py-1 px-3 small" href="/fees/collect">Collect Payment</a></li>
                                        <li><a class="dropdown-item py-1 px-3 small" href="/fees/report">Earnings Report</a></li>
                                    </ul>
                                </div>
                            </div>
                            <div class="mt-4">
                                <h2 class="text-white display-6 fw-bold mb-1"><%= stats.pendingFees.toLocaleString() %></h2>
                                <p class="text-white text-opacity-75 small mb-0 fw-medium">Outstanding payments (KES)</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Broadcast Institutional Announcement (Post Update) -->
                <div class="row g-4 mb-5">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm p-5 h-100" style="border-radius: 32px; background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <div class="stats-icon bg-primary bg-opacity-10 text-primary" style="width: 52px; height: 52px;">
                                    <i class="bi bi-megaphone-fill fs-3"></i>
                                </div>
                                <div>
                                    <h4 class="fw-bold text-main mb-1">Institutional Update Hub</h4>
                                    <p class="text-muted tiny mb-0 text-uppercase fw-bold">Broadcast text, images, or videos to the school portal.</p>
                                </div>
                            </div>
                            <form action="/dashboard/announcements" method="POST">
                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <label class="tiny text-muted fw-bold mb-2">UPDATE HEADING</label>
                                        <input type="text" name="title" class="form-control bg-white border-0 py-3 px-4 shadow-sm rounded-16" placeholder="e.g. Science Fair 2026" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="tiny text-muted fw-bold mb-2">TYPE</label>
                                        <select name="type" class="form-select bg-white border-0 py-3 px-4 shadow-sm rounded-16">
                                            <option value="text">Text only</option>
                                            <option value="image">With Image</option>
                                            <option value="video">With Video</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="tiny text-muted fw-bold mb-2">MEDIA URL</label>
                                        <input type="text" name="mediaUrl" class="form-control bg-white border-0 py-3 px-4 shadow-sm rounded-16" placeholder="https://...">
                                    </div>
                                    <div class="col-12">
                                        <label class="tiny text-muted fw-bold mb-2">UPDATE MESSAGE</label>
                                        <textarea name="message" class="form-control bg-white border-0 py-3 px-4 shadow-sm rounded-20" rows="3" placeholder="Enter your bulletin message here..." required></textarea>
                                    </div>
                                    <div class="col-12 text-end">
                                        <button type="submit" class="btn btn-primary px-5 py-3 rounded-20 fw-bold shadow-md">
                                            <i class="bi bi-send-check-fill me-2 fs-5"></i> Broadcast Bulletin
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm p-4 h-100 bg-white" style="border-radius: 32px;">
                            <h5 class="fw-bold text-main mb-4">Quick Governance</h5>
                            <div class="d-grid gap-3">
                                <a href="/dashboard/users" class="btn btn-light text-start py-4 px-4 rounded-24 d-flex align-items-center justify-content-between border-0 shadow-sm">
                                    <span class="small fw-bold text-muted"><i class="bi bi-person-gear-fill me-3 text-primary fs-4"></i> Manage Users</span>
                                    <i class="bi bi-chevron-right tiny opacity-50"></i>
                                </a>
                                <a href="/dashboard/tickets" class="btn btn-light text-start py-4 px-4 rounded-24 d-flex align-items-center justify-content-between border-0 shadow-sm">
                                    <span class="small fw-bold text-muted"><i class="bi bi-shield-lock-fill me-3 text-warning fs-4"></i> Support Portal</span>
                                    <i class="bi bi-chevron-right tiny opacity-50"></i>
                                </a>
                                <div class="mt-4 p-4 text-center rounded-32 bg-primary bg-opacity-5">
                                    <div class="h2 fw-bold text-primary mb-1"><%= stats.online %></div>
                                    <p class="tiny text-muted fw-bold text-uppercase mb-0">Total Live Active Users</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts & Analytics Section -->
                <div class="row g-4 mb-5">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm p-4 h-100">

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="mb-0">Revenue Overview</h5>
                                <select class="form-select form-select-sm border-0 bg-light fw-medium" style="width: 120px;">
                                    <option>Monthly</option>
                                    <option>Weekly</option>
                                    <option>Yearly</option>
                                </select>
                            </div>
                            <div style="height: 350px;">
                                <canvas id="revenueChart"></canvas>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm p-4 h-100">
                            <h5 class="mb-4">Attendance Stats</h5>
                            <div style="height: 250px;" class="mb-4">
                                <canvas id="attendanceChart"></canvas>
                            </div>
                            <div class="attendance-labels mt-2">
                                <div class="d-flex justify-content-between align-items-center mb-2 px-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle" style="width: 10px; height: 10px; background: #10b981;"></div>
                                        <span class="small text-muted fw-medium">Present</span>
                                    </div>
                                    <span class="small fw-bold">0%</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2 px-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle" style="width: 10px; height: 10px; background: #f59e0b;"></div>
                                        <span class="small text-muted fw-medium">Late</span>
                                    </div>
                                    <span class="small fw-bold">0%</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center px-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle" style="width: 10px; height: 10px; background: #ef4444;"></div>
                                        <span class="small text-muted fw-medium">Absent</span>
                                    </div>
                                    <span class="small fw-bold">0%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activities & Table -->
                <div class="row">
                    <div class="col">
                        <div class="card border-0 shadow-sm overflow-hidden">
                            <div class="p-4 d-flex justify-content-between align-items-center border-bottom">
                                <h5 class="mb-0">Recent Activities</h5>
                                <button class="btn btn-outline-primary btn-sm rounded-8 px-3 fw-bold">View All</button>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light bg-opacity-50">
                                        <tr>
                                            <th class="ps-4 border-0 text-uppercase small text-muted font-monospace py-3">User</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3">Activity</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3">Date</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3">Status</th>
                                            <th class="pe-4 border-0 text-uppercase small text-muted font-monospace py-3 text-end">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (stats.recentActivities && stats.recentActivities.length > 0) { %>
                                            <% stats.recentActivities.forEach(activity => { %>
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="d-flex align-items-center gap-3">
                                                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                                                <i class="bi bi-person text-primary"></i>
                                                            </div>
                                                            <div class="fw-bold small text-main"><%= activity.user %></div>
                                                        </div>
                                                    </td>
                                                    <td class="py-3">
                                                        <span class="small text-muted"><%= activity.description %></span>
                                                    </td>
                                                    <td class="py-3">
                                                        <span class="small text-muted"><%= moment(activity.date).format('MMM DD, YYYY') %></span>
                                                    </td>
                                                    <td class="py-3">
                                                        <span class="badge rounded-pill bg-<%= activity.status === 'completed' ? 'success' : 'warning' %> bg-opacity-10 text-<%= activity.status === 'completed' ? 'success' : 'warning' %> px-3 border border-<%= activity.status === 'completed' ? 'success' : 'warning' %> border-opacity-25" style="font-size: 11px;">
                                                            <%= activity.status.toUpperCase() %>
                                                        </span>
                                                    </td>
                                                    <td class="pe-4 py-3 text-end">
                                                        <i class="bi bi-three-dots text-muted cursor-pointer"></i>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center py-5">
                                                    <div class="text-muted d-flex flex-column align-items-center">
                                                        <i class="bi bi-inboxes display-4 mb-2"></i>
                                                        <p class="mb-0">No recent activities available</p>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        // Revenue Chart
        const revenueCtx = document.getElementById('revenueChart').getContext('2d');
        new Chart(revenueCtx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
                datasets: [{
                    label: 'Fees Collected (KES)',
                    data: [0, 0, 0, 0, 0, 0, 0], // Empty data to be populated dynamically later
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99, 102, 241, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    borderWidth: 3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { 
                        beginAtZero: true,
                        grid: { borderDash: [5, 5] },
                        ticks: { font: { family: 'Inter', size: 10 } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: 'Inter', size: 10 } }
                    }
                }
            }
        });

        // Attendance Chart
        const attendanceCtx = document.getElementById('attendanceChart').getContext('2d');
        new Chart(attendanceCtx, {
            type: 'doughnut',
            data: {
                labels: ['Present', 'Late', 'Absent'],
                datasets: [{
                    data: [0, 0, 0], // Empty data points replacing the mocks
                    backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 12
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '80%',
                plugins: {
                    legend: { display: false }
                }
            }
        });

        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>