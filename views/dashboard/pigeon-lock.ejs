<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main h-100">
    <div class="dashboard-wrapper">
        <%- include('../layouts/sidebar') %>

        <main class="main-content">
            <%- include('../layouts/header') %>

            <div class="d-flex align-items-center justify-content-center mt-5">
                <div class="card border-0 shadow-lg p-5 text-center animate-up" style="max-width: 450px; border-radius: 24px;">
                    <div class="mb-4">
                        <div class="d-inline-flex bg-danger bg-opacity-10 text-danger rounded-circle p-4 mb-3">
                            <i class="bi bi-shield-lock-fill display-4"></i>
                        </div>
                        <h3 class="fw-bold text-main">Secure Vault</h3>
                        <p class="text-muted small">This area contains highly sensitive auto-generated credentials ("The Pigeon Hole"). Please enter the Master Secret Key to continue.</p>
                    </div>

                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger bg-danger bg-opacity-10 border-danger border-opacity-25 text-danger rounded-12 small fw-bold">
                            <i class="bi bi-x-circle-fill me-2"></i><%= error %>
                        </div>
                    <% } %>

                    <form action="/dashboard/pigeon/auth" method="POST">
                        <div class="form-floating mb-4">
                            <input type="password" name="secretKey" class="form-control bg-light border-0 py-3 px-4 fw-bold text-center letter-spacing-2" id="secretKey" placeholder="Secret Key" required>
                            <label for="secretKey">Master Secret Key</label>
                        </div>
                        <button type="submit" class="btn btn-danger w-100 py-3 rounded-12 fw-bold shadow-sm">
                            <i class="bi bi-unlock-fill me-2"></i>Unlock Vault
                        </button>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>
