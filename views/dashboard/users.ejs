<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <%- include('../layouts/sidebar', { currentUrl: '/dashboard/users' }) %>
        <main class="main-content">
            <%- include('../layouts/header') %>

            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="h3 fw-bold text-main mb-1">User & Access Management</h2>
                        <p class="text-muted small mb-0">Elevate administrative status or temporarily suspend institutional portal access.</p>
                    </div>
                </div>

                <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 24px;">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="text-muted tiny text-uppercase fw-bold">
                                    <th class="px-4 py-3">Full Name & ID</th>
                                    <th class="px-4 py-3">Institutional Role</th>
                                    <th class="px-4 py-3">Access Status</th>
                                    <th class="px-4 py-3 text-end">Manage Privileges</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (users && users.length > 0) { %>
                                    <% users.forEach(u => { %>
                                        <tr>
                                            <td class="px-4 py-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="stats-icon bg-primary bg-opacity-10 text-primary me-3" style="width: 44px; height: 44px; border-radius: 14px;">
                                                        <i class="bi bi-person-fill fs-5"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold text-main small text-truncate" style="max-width: 150px;"><%= u.firstName %> <%= u.lastName %></div>
                                                        <div class="text-muted tiny"><%= u.username || u.email %></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="px-4">
                                                <div class="badge bg-light text-main border px-3 py-2 rounded-pill tiny fw-bold text-uppercase"><%= u.role %></div>
                                            </td>
                                            <td class="px-4">
                                                <span class="badge rounded-pill tiny px-3 p-2 fw-bold <%= u.isActive ? 'bg-success bg-opacity-10 text-success border-success' : 'bg-danger bg-opacity-10 text-danger border-danger' %> border">
                                                    <%= u.isActive ? 'Active Access' : 'Suspended' %>
                                                </span>
                                            </td>
                                            <td class="px-4 text-end">
                                                <div class="d-flex gap-2 justify-content-end">
                                                    <form action="/dashboard/users/<%= u._id %>/suspend" method="POST" class="d-inline">
                                                        <button type="submit" class="btn btn-sm <%= u.isActive ? 'btn-outline-danger' : 'btn-success' %> rounded-pill px-3 tiny fw-bold">
                                                            <%= u.isActive ? 'Suspend' : 'Activate' %>
                                                        </button>
                                                    </form>
                                                    <form action="/dashboard/users/<%= u._id %>/role" method="POST" class="d-inline">
                                                        <input type="hidden" name="role" value="<%= u.role === 'admin' ? 'student' : 'admin' %>">
                                                        <button type="submit" class="btn btn-sm <%= u.role === 'admin' ? 'btn-outline-secondary' : 'btn-primary' %> rounded-pill px-3 tiny fw-bold">
                                                            <%= u.role === 'admin' ? 'Revoke Admin' : 'Make Admin' %>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
