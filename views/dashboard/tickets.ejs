<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart Support</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <%- include('../layouts/sidebar', { currentUrl: '/dashboard/tickets' }) %>
        <main class="main-content">
            <%- include('../layouts/header') %>

            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="h3 fw-bold text-main mb-1">Institutional Support Requests</h2>
                        <p class="text-muted small mb-0">Manage account recovery and portal technical issues submitted by staff and students.</p>
                    </div>
                </div>

                <div class="row g-4">
                    <% if (tickets && tickets.length > 0) { %>
                        <% tickets.forEach(t => { %>
                            <div class="col-12">
                                <div class="card border-0 shadow-sm p-4" style="border-radius: 24px;">
                                    <div class="row align-items-center">
                                        <div class="col-md-2">
                                            <div class="stats-icon bg-warning bg-opacity-10 text-warning mb-2" style="width: 44px; height: 44px;">
                                                <i class="bi bi-ticket-perforated-fill fs-5"></i>
                                            </div>
                                            <span class="tiny text-muted fw-bold d-block text-uppercase"><%= t.ticketId %></span>
                                            <span class="tiny text-muted"><%= moment(t.createdAt).fromNow() %></span>
                                        </div>
                                        <div class="col-md-3 border-start">
                                            <div class="fw-bold text-main small">Applicant Credentials</div>
                                            <div class="text-muted tiny">ID: <%= t.credentialId %></div>
                                            <div class="text-primary tiny fw-bold"><%= t.contactEmail %></div>
                                        </div>
                                        <div class="col-md-4 border-start">
                                            <div class="fw-bold text-main small">Problem Description</div>
                                            <p class="text-muted tiny mb-0"><%= t.description %></p>
                                        </div>
                                        <div class="col-md-3 text-end">
                                            <div class="mb-3">
                                                <span class="badge rounded-pill tiny px-3 py-2 fw-bold text-uppercase <%= t.status === 'pending' ? 'bg-warning bg-opacity-10 text-warning' : (t.status === 'complete' ? 'bg-success bg-opacity-10 text-success' : 'bg-secondary bg-opacity-10 text-secondary') %> border">
                                                    <%= t.status %> Status
                                                </span>
                                            </div>
                                            <!-- Action Buttons -->
                                            <div class="d-flex gap-2 justify-content-end">
                                                <form action="/dashboard/tickets/<%= t._id %>/status" method="POST" class="d-inline">
                                                    <select name="status" class="form-select form-select-sm tiny border-0 bg-light rounded-pill px-3" onchange="this.form.submit()">
                                                        <option value="pending" <%= t.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                                        <option value="active" <%= t.status === 'active' ? 'selected' : '' %>>Active</option>
                                                        <option value="complete" <%= t.status === 'complete' ? 'selected' : '' %>>Complete</option>
                                                        <option value="deleted" <%= t.status === 'deleted' ? 'selected' : '' %>>Delete</option>
                                                    </select>
                                                </form>
                                                <a href="mailto:<%= t.contactEmail %>?subject=Regarding Support Ticket <%= t.ticketId %>" class="btn btn-sm btn-primary rounded-pill px-3 tiny fw-bold">
                                                    <i class="bi bi-reply-fill me-1"></i> Email Reply
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <i class="bi bi-check2-circle display-1 text-success opacity-25"></i>
                            <h4 class="text-muted mt-3">No active institutional tickets</h4>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
