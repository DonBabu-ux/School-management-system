<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- User Dashboard Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-5 bg-primary bg-opacity-10 p-5 rounded-32 shadow-soft overflow-hidden position-relative">
                    <div class="position-relative z-index-1">
                        <h2 class="h3 text-main mb-1 fw-bold">Welcome back, <%= user.firstName %>! 👋</h2>
                        <p class="text-muted small mb-0 fw-medium">Role: <%= user.role.toUpperCase() %> Portal</p>
                    </div>
                </div>

                <!-- Features Cards Row -->
                <div class="row g-4">
                    <% if (user.role === 'student') { %>
                        <!-- Student Dashboard Content -->
                        <div class="col-xl-4 col-md-6">
                            <div class="card border-0 shadow-sm p-4 h-100 animate-up text-center d-flex flex-column align-items-center">
                                <div class="stats-icon bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
                                    <i class="bi bi-book-half"></i>
                                </div>
                                <h5 class="fw-bold mb-2">My Courses</h5>
                                <p class="small text-muted mb-4 px-3 italic">Browse your enrolled subjects, course materials, and progress tracks.</p>
                                <a href="/courses" class="btn btn-outline-primary rounded-pill px-4 btn-sm mt-auto">View Modules</a>
                            </div>
                        </div>
                        
                        <div class="col-xl-4 col-md-6">
                            <div class="card border-0 shadow-sm p-4 h-100 animate-up text-center d-flex flex-column align-items-center">
                                <div class="stats-icon bg-success bg-opacity-10 text-success mb-3 mx-auto">
                                    <i class="bi bi-calendar-check-fill"></i>
                                </div>
                                <h5 class="fw-bold mb-2">Attendance</h5>
                                <p class="small text-muted mb-4 px-3 italic">Monitor your daily attendance records and manage your leave applications.</p>
                                <a href="/attendance/my" class="btn btn-outline-success rounded-pill px-4 btn-sm mt-auto">History</a>
                            </div>
                        </div>
                        
                        <div class="col-xl-4 col-md-12">
                            <div class="card border-0 shadow-sm p-4 h-100 animate-up text-center d-flex flex-column align-items-center">
                                <div class="stats-icon bg-info bg-opacity-10 text-info mb-3 mx-auto">
                                    <i class="bi bi-patch-check-fill"></i>
                                </div>
                                <h5 class="fw-bold mb-2">Exam Results</h5>
                                <p class="small text-muted mb-4 px-3 italic">Securely access your academic results, report cards, and semester summaries.</p>
                                <a href="/exams/results" class="btn btn-outline-info rounded-pill px-4 btn-sm mt-auto">Report Card</a>
                            </div>
                        </div>

                    <% } else if (user.role === 'teacher') { %>
                        <!-- Teacher Dashboard Content -->
                        <div class="col-xl-4 col-md-6">
                            <div class="card border-0 shadow-sm p-4 h-100 animate-up text-center d-flex flex-column align-items-center">
                                <div class="stats-icon bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
                                    <i class="bi bi-journal-check"></i>
                                </div>
                                <h5 class="fw-bold mb-2">My Classes</h5>
                                <p class="small text-muted mb-4 px-3 italic">Manage your classroom assignments, student directories, and timetables.</p>
                                <a href="/classes/my" class="btn btn-outline-primary rounded-pill px-4 btn-sm mt-auto">Classroom</a>
                            </div>
                        </div>
                        
                        <div class="col-xl-4 col-md-6">
                            <div class="card border-0 shadow-sm p-4 h-100 animate-up text-center d-flex flex-column align-items-center">
                                <div class="stats-icon bg-warning bg-opacity-10 text-warning mb-3 mx-auto">
                                    <i class="bi bi-hand-index-thumb"></i>
                                </div>
                                <h5 class="fw-bold mb-2">Daily Attendance</h5>
                                <p class="small text-muted mb-4 px-3 italic">Quickly mark and finalize student registers for your assigned streams today.</p>
                                <a href="/attendance/mark" class="btn btn-outline-warning rounded-pill px-4 btn-sm mt-auto">Mark Register</a>
                            </div>
                        </div>
                        
                        <div class="col-xl-4 col-md-12">
                            <div class="card border-0 shadow-sm p-4 h-100 animate-up text-center d-flex flex-column align-items-center">
                                <div class="stats-icon bg-danger bg-opacity-10 text-danger mb-3 mx-auto">
                                    <i class="bi bi-file-earmark-plus"></i>
                                </div>
                                <h5 class="fw-bold mb-2">Assignments</h5>
                                <p class="small text-muted mb-4 px-3 italic">Design, allocate, and grade student assignments and project submissions.</p>
                                <a href="/assignments" class="btn btn-outline-danger rounded-pill px-4 btn-sm mt-auto">Assessments</a>
                            </div>
                        </div>

                    <% } else { %>
                        <!-- Default placeholder -->
                        <div class="col-12 py-5 text-center">
                            <div class="opacity-25 mb-3 fs-1"><i class="bi bi-folder-symlink"></i></div>
                            <p class="text-muted italic">Your personalized dashboard modules are being initialized by the administration.</p>
                        </div>
                    <% } %>
                </div>

                <div class="mt-5 p-5 bg-white border-0 shadow-sm rounded-32 d-flex align-items-center justify-content-between gap-5 position-relative overflow-hidden">
                    <div class="z-index-1">
                        <h5 class="fw-bold text-main mb-2">Institutional Announcements</h5>
                        <p class="small text-muted mb-0">Stay updated with the latest news, events, and circulars directly from the administration office. Check back often for new policy updates.</p>
                    </div>
                    <a href="/announcements" class="btn btn-light rounded-pill border px-4 shadow-sm z-index-1">Explore News</a>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>