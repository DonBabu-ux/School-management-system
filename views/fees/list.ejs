<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2>Fee Transactions</h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/fees/collect" class="btn btn-primary"><i class="bi bi-cash-stack"></i> Collect Fee</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <% if (fees && fees.length) { %>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Student</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% fees.forEach(f => { %>
                        <tr>
                            <td><%= f.date.toLocaleDateString() %></td>
                            <td><%= f.student ? f.student.fullName : '' %></td>
                            <td><%= f.amount %></td>
                            <td><%= f.status %></td>
                            <td>
                                <a href="/fees/invoice/<%= f._id %>" class="btn btn-sm btn-secondary">Invoice</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p class="text-muted">No fee records found.</p>
        <% } %>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>