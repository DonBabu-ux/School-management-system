<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Fee Management Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Fee Management</h2>
                        <p class="text-muted small mb-0">Monitor fee transactions, collections, and financial reports.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/fees/report" class="btn btn-outline-secondary border-0 bg-white shadow-sm">
                            <i class="bi bi-file-earmark-bar-graph me-2"></i>Financial Report
                        </a>
                        <a href="/fees/structure" class="btn btn-info text-white me-2">
                            <i class="bi bi-list-columns-reverse me-2"></i>Set Structure
                        </a>
                        <a href="/fees/collect" class="btn btn-primary">
                            <i class="bi bi-credit-card-2-front-fill me-2"></i>Collect Fee
                        </a>
                    </div>
                </div>

                <!-- Summary Cards Row -->
                <div class="row g-4 mb-5">
                    <div class="col-md-4">
                        <div class="card p-4 h-100 border-0 shadow-sm glass">
                            <div class="d-flex align-items-center gap-3">
                                <div class="stats-icon bg-success bg-opacity-10 text-success mb-0" style="width: 48px; height: 48px;">
                                    <i class="bi bi-check-circle-fill"></i>
                                </div>
                                <div>
                                    <h6 class="text-muted small fw-bold text-uppercase mb-1">Total Collected</h6>
                                    <h4 class="mb-0 text-success fw-bold">KES <%= (fees || []).reduce((acc, f) => acc + (f.amount || 0), 0).toLocaleString() %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Fee Transactions Table -->
                <div class="card border-0 shadow-sm overflow-hidden animate-up">
                    <div class="p-4 d-flex justify-content-between align-items-center border-bottom bg-white">
                        <h5 class="mb-0">Recent Transactions</h5>
                        <div class="input-group" style="width: 250px;">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control bg-light border-0 small" placeholder="Search transactions...">
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 border-0 text-uppercase small text-muted font-monospace py-3">Receipt ID</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Student</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Amount</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Method</th>
                                    <th class="border-0 text-uppercase small text-muted font-monospace py-3">Date</th>
                                    <th class="pe-4 border-0 text-uppercase small text-muted font-monospace py-3 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (fees && fees.length > 0) { %>
                                    <% fees.forEach(fee => { %>
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <span class="font-monospace text-primary fw-bold" style="font-size: 11px;">#REC-<%= fee._id.toString().slice(-6).toUpperCase() %></span>
                                            </td>
                                            <td class="py-3">
                                                <% if (fee.student) { %>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 12px;">
                                                            <i class="bi bi-person text-secondary"></i>
                                                        </div>
                                                        <div class="fw-bold small text-main"><%= fee.student.firstName %> <%= fee.student.lastName %></div>
                                                    </div>
                                                <% } else { %>
                                                    <span class="text-muted small italic">Unknown Student</span>
                                                <% } %>
                                            </td>
                                            <td class="py-3">
                                                <span class="fw-bold text-main">KES <%= fee.amount.toLocaleString() %></span>
                                            </td>
                                            <td class="py-3">
                                                <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3 border border-info border-opacity-25" style="font-size: 10px;">
                                                    <%= fee.description || 'General' %>
                                                </span>
                                            </td>
                                            <td class="py-3">
                                                <span class="small text-muted"><%= new Date(fee.date).toLocaleDateString('en-GB') %></span>
                                            </td>
                                            <td class="pe-4 py-3 text-end">
                                                <a href="/fees/invoice/<%= fee._id %>" class="btn btn-light btn-sm rounded-8 border">
                                                    <i class="bi bi-printer me-1"></i>Receipt
                                                </a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="text-muted d-flex flex-column align-items-center opacity-50">
                                                <i class="bi bi-wallet2 display-3 mb-3"></i>
                                                <p class="mb-0">No fee transactions recorded in the system yet.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>