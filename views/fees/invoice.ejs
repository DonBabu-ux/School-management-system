<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2>Invoice</h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/fees" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <% if (fee) { %>
            <p><strong>Student:</strong> <%= fee.student.fullName %></p>
            <p><strong>Admission No:</strong> <%= fee.student.admissionNumber %></p>
            <p><strong>Date:</strong> <%= fee.date.toLocaleDateString() %></p>
            <p><strong>Amount:</strong> ₹<%= fee.amount %></p>
            <p><strong>Status:</strong> <%= fee.status %></p>
            <p><strong>Description:</strong> <%= fee.description || '-' %></p>
        <% } else { %>
            <p class="text-muted">Invoice not available.</p>
        <% } %>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>