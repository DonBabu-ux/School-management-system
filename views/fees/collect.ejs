<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Collect Fee Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Collect Fees</h2>
                        <p class="text-muted small mb-0">Record a new payment transaction with instant receipt generation.</p>
                    </div>
                    <a href="/fees" class="btn btn-outline-secondary border-0 bg-white shadow-sm">
                        <i class="bi bi-arrow-left me-2"></i>Back to List
                    </a>
                </div>

                <% if (error) { %>
                    <div class="alert alert-danger mb-4 shadow-sm border-0 d-flex align-items-center rounded-16 p-3 animate-up">
                        <i class="bi bi-exclamation-triangle-fill me-3 fs-3"></i>
                        <div class="small fw-medium"><%= error %></div>
                    </div>
                <% } %>

                <div class="row g-4">
                    <!-- Collect Fee Form -->
                    <div class="col-lg-7">
                        <div class="card border-0 shadow-sm p-4 h-100">
                            <form action="/fees/collect" method="POST">
                                <h6 class="mb-4 text-muted small text-uppercase fw-bold"><i class="bi bi-person-check me-2"></i>Payment Information</h6>
                                
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Select Recipient Student</label>
                                    <select name="studentId" class="form-select bg-light border-0 py-3" required id="studentSelect">
                                        <option value="">Search by Name or Admission #...</option>
                                        <% students.forEach(s => { %>
                                            <option value="<%= s._id %>"><%= s.firstName %> <%= s.lastName %> (<%= s.admissionNumber %>)</option>
                                        <% }) %>
                                    </select>
                                </div>

                                <div class="row g-4">
                                    <div class="col-md-6 mb-4">
                                        <label class="form-label fw-bold small text-muted">Amount Collected</label>
                                        <div class="input-group border bg-light rounded-12 p-1" style="height: 52px;">
                                            <span class="input-group-text bg-transparent border-0 fw-bold border-end" style="color: var(--primary);">KES</span>
                                            <input type="number" name="amount" class="form-control bg-transparent border-0 fw-bold" placeholder="0.00" required step="0.01">
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-4">
                                        <label class="form-label fw-bold small text-muted">Academic Term / Sem</label>
                                        <select name="term" class="form-select bg-light border-0 py-3" required>
                                            <option value="Term 1">Term 1</option>
                                            <option value="Term 2">Term 2</option>
                                            <option value="Term 3">Term 3</option>
                                            <option value="Semester 1">Semester 1</option>
                                            <option value="Semester 2">Semester 2</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-4">
                                        <label class="form-label fw-bold small text-muted">Academic Year</label>
                                        <select name="academicYear" class="form-select bg-light border-0 py-3" required>
                                            <option value="2024-2025">2024-2025</option>
                                            <option value="2025-2026">2025-2026</option>
                                            <option value="2026-2027">2026-2027</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-4">
                                        <label class="form-label fw-bold small text-muted">Fee Type / Category</label>
                                        <select name="description" class="form-select bg-light border-0 py-3">
                                            <option value="Tuition Fee">Tuition Fee</option>
                                            <option value="Exam Fee">Exam Fee</option>
                                            <option value="Transport Fee">Transport Fee</option>
                                            <option value="Uniform/Books">Uniform/Books</option>
                                            <option value="Library Fee">Library Fee</option>
                                            <option value="Other Misc">Other Misc</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Collection Method</label>
                                    <div class="d-flex gap-3">
                                        <div class="flex-grow-1">
                                            <input type="radio" class="btn-check" name="method" id="cash" checked value="Cash">
                                            <label class="btn btn-outline-light w-100 border p-3 rounded-12 text-muted fw-bold d-flex flex-column align-items-center gap-2" for="cash">
                                                <i class="bi bi-cash fs-4"></i>Cash
                                            </label>
                                        </div>
                                        <div class="flex-grow-1">
                                            <input type="radio" class="btn-check" name="method" id="bank" value="Bank">
                                            <label class="btn btn-outline-light w-100 border p-3 rounded-12 text-muted fw-bold d-flex flex-column align-items-center gap-2" for="bank">
                                                <i class="bi bi-bank fs-4"></i>Bank Transfer
                                            </label>
                                        </div>
                                        <div class="flex-grow-1">
                                            <input type="radio" class="btn-check" name="method" id="mpesa" value="MPESA">
                                            <label class="btn btn-outline-light w-100 border p-3 rounded-12 text-muted fw-bold d-flex flex-column align-items-center gap-2" for="mpesa">
                                                <i class="bi bi-phone-vibrate fs-4"></i>MPESA
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <div class="alert alert-light border shadow-none rounded-12 p-3 mb-4 d-flex align-items-start gap-3">
                                    <input type="checkbox" name="sendSMS" class="mt-1" checked>
                                    <div class="small text-muted fw-medium">Automatically send an instant payment confirmation SMS to the registered parent's phone number.</div>
                                </div>

                                <div class="text-end">
                                    <button type="submit" class="btn btn-primary px-5 py-3 rounded-16 shadow-lg fw-bold w-100">
                                        Generate Receipt & Record Transaction
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Side Column: Info & Preview -->
                    <div class="col-lg-5">
                        <div class="card border-0 shadow-sm p-4 mb-4 bg-primary text-white" style="background: linear-gradient(145deg, #6366f1 0%, #4338ca 100%);">
                            <h6 class="mb-4 small text-uppercase fw-bold text-white-50">Quick Reference</h6>
                            <h2 class="display-6 fw-bold mb-4">KES <%= typeof totalCollected !== 'undefined' ? totalCollected.toLocaleString() : '0' %></h2>
                            <p class="small text-white-50 mb-4 fw-medium">Total fees collected in the current academic term so far.</p>
                            <div class="progress bg-white bg-opacity-20 mb-2" style="height: 10px;">
                                <div class="progress-bar bg-white" role="progressbar" style="width: <%= typeof progressPercent !== 'undefined' ? progressPercent : 0 %>%;"></div>
                            </div>
                            <div class="text-end small fw-bold"><%= typeof progressPercent !== 'undefined' ? progressPercent : 0 %>% Collected</div>
                        </div>

                        <div class="card border-0 shadow-sm p-4 mb-4">
                            <h6 class="mb-4 text-muted small text-uppercase fw-bold">Payment Preview</h6>
                            <div class="rounded-16 border border-dashed p-4 text-center">
                                <div class="fs-1 text-muted opacity-25 mb-3"><i class="bi bi-receipt"></i></div>
                                <p class="text-muted small mb-0 fw-medium">Selected student information and pending balance will appear here during selection.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>