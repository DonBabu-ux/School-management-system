<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2>Fees for <%= student.fullName %></h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/fees" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <% if (fees && fees.length) { %>
            <table class="table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <% fees.forEach(f => { %>
                        <tr>
                            <td><%= f.date.toLocaleDateString() %></td>
                            <td><%= f.amount %></td>
                            <td><%= f.status %></td>
                            <td><%= f.description %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p class="text-muted">No fee records for this student.</p>
        <% } %>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>