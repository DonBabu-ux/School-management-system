<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2>Fee Report</h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/fees" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form action="/fees/report" method="POST" class="row g-3">
            <div class="col-md-4">
                <label for="classId" class="form-label">Class</label>
                <select name="classId" id="classId" class="form-control">
                    <option value="">All classes</option>
                    <% classes.forEach(c => { %>
                        <option value="<%= c._id %>" <%= classId == c._id ? 'selected' : '' %>><%= c.className %> <%= c.section %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-3">
                <label for="startDate" class="form-label">From</label>
                <input type="date" name="startDate" id="startDate" class="form-control" value="<%= startDate || '' %>">
            </div>
            <div class="col-md-3">
                <label for="endDate" class="form-label">To</label>
                <input type="date" name="endDate" id="endDate" class="form-control" value="<%= endDate || '' %>">
            </div>
            <div class="col-md-2 align-self-end">
                <button class="btn btn-primary">Generate</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <% if (report && report.length) { %>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Student</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% report.forEach(r => { %>
                        <tr>
                            <td><%= r.date.toLocaleDateString() %></td>
                            <td><%= r.student ? r.student.fullName : '' %></td>
                            <td><%= r.amount %></td>
                            <td><%= r.status %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else if (report) { %>
            <p class="text-muted">No records found for the selected period.</p>
        <% } else { %>
            <p class="text-muted">Use the form above to generate a report.</p>
        <% } %>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>