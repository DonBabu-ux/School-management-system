<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('../layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('../layouts/header') %>

            <!-- Fee Structure Content -->
            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="h3 text-main mb-1">Fee Structure & Policy</h2>
                        <p class="text-muted small mb-0">Define academic levies, termly charges, and institutional fee policies.</p>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Setup Form -->
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm p-4">
                            <h6 class="mb-4 text-muted small text-uppercase fw-bold"><i class="bi bi-gear-fill me-2"></i>Configure Structure</h6>
                            <form action="/fees/structure" method="POST">
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted">Assigned Class</label>
                                    <select name="classId" class="form-select bg-light border-0 py-3" required>
                                        <option value="">Select Stream...</option>
                                        <% classes.forEach(c => { %>
                                            <option value="<%= c._id %>"><%= c.className %> - <%= c.section %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted">Amount (KES)</label>
                                    <input type="number" name="amount" class="form-control bg-light border-0 py-3" placeholder="e.g. 50000" required>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Policy Description</label>
                                    <textarea name="description" class="form-control bg-light border-0" rows="3" placeholder="Inclusive of lunch, etc."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 py-3 rounded-12 shadow-md fw-bold">
                                    Apply Configuration
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Current Structures -->
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm overflow-hidden animate-up">
                            <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center">
                                <h6 class="mb-0 text-main fw-bold">Active Fee Policies</h6>
                                <span class="badge bg-light text-muted border"><%= structures.length %> Classes Defined</span>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light bg-opacity-50">
                                        <tr>
                                            <th class="ps-4 border-0 text-uppercase small text-muted font-monospace py-3">Class/Stream</th>
                                            <th class="border-0 text-uppercase small text-muted font-monospace py-3">Standard Amount</th>
                                            <th class="pe-4 border-0 text-uppercase small text-muted font-monospace py-3 text-end">Last Updated</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (structures && structures.length > 0) { %>
                                            <% structures.forEach(struct => { %>
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="fw-bold text-main small"><%= struct.class ? struct.class.className + ' - ' + struct.class.section : 'UNASSIGNED' %></div>
                                                        <div class="text-muted" style="font-size: 10px;"><%= struct.description || 'No special notes' %></div>
                                                    </td>
                                                    <td class="py-3">
                                                        <span class="fw-bold text-main">KES <%= struct.amount.toLocaleString() %></span>
                                                    </td>
                                                    <td class="pe-4 py-3 text-end">
                                                        <span class="small text-muted"><%= new Date().toLocaleDateString() %></span>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="3" class="text-center py-5">
                                                    <div class="text-muted opacity-25">
                                                        <i class="bi bi-receipt display-4"></i>
                                                        <p class="mt-2 fw-medium">No fee structures defined yet</p>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    </script>
</body>
</html>