<% include ../layouts/header %>
<% include ../layouts/sidebar %>

<div class="row mb-3">
    <div class="col-md-6">
        <h2>Fee Structure</h2>
    </div>
    <div class="col-md-6 text-end">
        <a href="/fees" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form action="/fees/structure" method="POST" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="classId" class="form-label">Class</label>
                <select name="classId" id="classId" class="form-control" required>
                    <option value="">-- choose --</option>
                    <% classes.forEach(c => { %>
                        <option value="<%= c._id %>"><%= c.className %> <%= c.section %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-3">
                <label for="amount" class="form-label">Amount</label>
                <input type="number" name="amount" id="amount" class="form-control" required>
            </div>
            <div class="col-md-3">
                <label for="description" class="form-label">Description</label>
                <input type="text" name="description" id="description" class="form-control">
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary">Save Structure</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <% if (structures && structures.length) { %>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Class</th>
                        <th>Amount</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <% structures.forEach(s => { %>
                        <tr>
                            <td><%= s.class ? s.class.className + ' ' + s.class.section : '' %></td>
                            <td><%= s.amount %></td>
                            <td><%= s.description %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p class="text-muted">No fee structure defined yet.</p>
        <% } %>
    </div>
</div>

<% include ../layouts/footer %>
<% include ../layouts/close-sidebar %>