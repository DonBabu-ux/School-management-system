<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart</title>
    
    <!-- Fonts & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-main">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <%- include('layouts/sidebar') %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <%- include('layouts/header') %>

            <div class="animate-up">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="h3 text-main mb-1">Subject Management</h2>
                        <p class="text-muted small mb-0">Define and manage academic subjects</p>
                    </div>
                    <% if (user && user.role === 'admin') { %>
                        <button class="btn btn-primary px-4 py-2 rounded-12 shadow-sm" data-bs-toggle="modal" data-bs-target="#addSubjectModal">
                            <i class="bi bi-plus-lg me-2"></i> Add New Subject
                        </button>
                    <% } %>
                </div>

                <div class="row g-4">
                    <% if (subjects && subjects.length > 0) { %>
                        <% subjects.forEach(subject => { %>
                            <div class="col-md-4 col-sm-6">
                                <div class="card border-0 shadow-sm h-100 p-4" style="border-radius: 20px;">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <div class="stats-icon bg-primary bg-opacity-10 text-primary mb-0" style="width: 48px; height: 48px;">
                                            <i class="bi bi-book-half"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold text-main mb-0"><%= subject.subjectName %></h5>
                                            <span class="tiny text-muted fw-bold text-uppercase"><%= subject.subjectCode %></span>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="small text-muted">Category</span>
                                            <span class="small fw-bold"><%= subject.category || 'Standard' %></span>
                                        </div>
                                        <div class="d-flex justify-content-between">
                                            <span class="small text-muted">Department</span>
                                            <span class="small fw-bold"><%= subject.department || 'General' %></span>
                                        </div>
                                    </div>
                                    <% if (user && user.role === 'admin') { %>
                                        <div class="mt-auto d-flex gap-2">
                                            <button class="btn btn-light btn-sm flex-grow-1 rounded-8 py-2 text-muted fw-bold">Edit</button>
                                            <a href="/subjects/delete/<%= subject._id %>" class="btn btn-light text-danger btn-sm rounded-8 py-2 px-3"><i class="bi bi-trash3"></i></a>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12">
                            <div class="card border-0 shadow-sm p-5 text-center bg-white" style="border-radius: 24px;">
                                <i class="bi bi-journal-x display-1 text-muted opacity-25 mb-3"></i>
                                <h4 class="fw-bold text-dark">No Subjects Found</h4>
                                <p class="text-muted">Start by adding a new academic subject to the system.</p>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <!-- Add Subject Modal -->
    <div class="modal fade" id="addSubjectModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
                <div class="modal-header border-0 px-4 pt-4">
                    <h5 class="modal-title fw-bold">Add New Subject</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    <form action="/subjects/add" method="POST">
                        <div class="mb-3">
                            <label class="tiny fw-bold text-muted mb-2 text-uppercase">Subject Name</label>
                            <input type="text" name="subjectName" class="form-control py-3 px-4 bg-light border-0 rounded-16" placeholder="e.g. Mathematics" required>
                        </div>
                        <div class="mb-3">
                            <label class="tiny fw-bold text-muted mb-2 text-uppercase">Subject Code</label>
                            <input type="text" name="subjectCode" class="form-control py-3 px-4 bg-light border-0 rounded-16" placeholder="e.g. MATH101" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="tiny fw-bold text-muted mb-2 text-uppercase">Category</label>
                                <select name="category" class="form-select py-3 px-4 bg-light border-0 rounded-16">
                                    <option value="Compulsory">Compulsory</option>
                                    <option value="Elective">Elective</option>
                                    <option value="Extra">Extra-Curricular</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="tiny fw-bold text-muted mb-2 text-uppercase">Department</label>
                                <input type="text" name="department" class="form-control py-3 px-4 bg-light border-0 rounded-16" placeholder="e.g. Sciences">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-16 fw-bold shadow-md">Create Subject</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
