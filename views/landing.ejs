<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EduSmart Academy</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root { --glass: rgba(255, 255, 255, 0.95); }
        body { font-family: 'Inter', sans-serif; letter-spacing: -0.015em; color: #0f172a; background: #fdfdfd; }
        .hero-premium { 
            padding: 120px 0 80px; 
            background: radial-gradient(circle at top left, rgba(99, 102, 241, 0.08), transparent 40%),
                        radial-gradient(circle at bottom right, rgba(165, 180, 252, 0.08), transparent 40%);
        }
        .hero-title { font-size: 3.5rem; letter-spacing: -0.04em; }
        .stat-badge-premium { font-size: 0.8rem; padding: 12px 28px; border-radius: 100px; background: white; box-shadow: 0 10px 30px rgba(0,0,0,0.04); border: 1px solid rgba(0,0,0,0.03); }
        .notice-card-v { border-radius: 28px; border: 1px solid rgba(0,0,0,0.04); background: white; padding: 24px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 20px rgba(0,0,0,0.02); }
        .notice-card-v:hover { transform: scale(1.02); border-color: var(--bs-primary); box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
        .memo-img-lg { width: 140px; height: 140px; border-radius: 20px; object-fit: cover; flex-shrink: 0; }
        .compressed-signin { padding: 32px; border-radius: 32px; background: white; border: 1px solid rgba(0,0,0,0.05); box-shadow: 0 20px 50px rgba(0,0,0,0.03); }
        .input-compressed { background: #f8fafc; border: 1px solid transparent; border-radius: 12px; padding: 10px 16px; font-size: 0.85rem; }
        .input-compressed:focus { background: white; border-color: var(--bs-primary); }
        .footer-mini { padding: 60px 0 30px; border-top: 1px solid rgba(0,0,0,0.03); background: white; }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top glass py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <div class="stats-icon bg-primary text-white mb-0" style="width: 36px; height: 36px;"><i class="bi bi-mortarboard-fill"></i></div>
                <span class="fw-bold h4 mb-0 text-main font-outfit">EduSmart</span>
            </a>
            <div class="d-none d-lg-flex align-items-center gap-3 ms-auto">
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 small fw-bold">
                    <i class="bi bi-circle-fill me-1" style="font-size: 6px;"></i> <%= stats.online %> ONLINE
                </span>
                <a href="#main-access" class="btn btn-primary px-4 py-2 rounded-pill fw-bold small">Portal Gateway</a>
            </div>
        </div>
    </nav>

    <!-- Styled Hero -->
    <section class="hero-premium text-center">
        <div class="container animate-up">
            <span class="badge bg-primary bg-opacity-10 text-primary px-4 py-2 rounded-pill fw-bold mb-4 tiny text-uppercase letter-spacing-1">Institutional Digital Future</span>
            <h1 class="hero-title fw-bold text-main mb-4 font-outfit">Excellence in <span class="text-primary italic">Education</span></h1>
            <p class="lead text-muted mx-auto mb-5 opacity-75" style="max-width: 700px;">
                The premier institutional ecosystem for administrative brilliance through secure, real-time data integration.
            </p>
            <div class="d-flex flex-wrap justify-content-center gap-4">
                <div class="stat-badge-premium">
                    <span class="text-muted fw-bold me-2 small">TOTAL PORTAL VISITS:</span>
                    <span class="text-primary fw-bold h5 mb-0"><%= stats.visits %></span>
                </div>
                <div class="stat-badge-premium">
                    <span class="text-muted fw-bold me-2 small">ACTIVE SESSIONS:</span>
                    <span class="text-success fw-bold h5 mb-0"><%= stats.online %></span>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content Area -->
    <section id="main-access" class="py-100">
        <div class="container px-xl-5">
            <div class="row g-5">
                <!-- Portal Sign In -->
                <div class="col-lg-4">
                    <div class="sticky-top" style="top: 100px;">
                        <div class="compressed-signin">
                            <div class="text-center mb-4">
                                <i class="bi bi-shield-lock-fill text-primary opacity-25 fs-1 d-block mb-3"></i>
                                <h5 class="fw-bold text-dark font-outfit mb-1">Portal Sign In</h5>
                                <p class="tiny text-muted fw-bold">System ID Entry Only</p>
                            </div>
                            <form action="/auth/login" method="POST">
                                <div class="mb-3">
                                    <label class="tiny fw-bold text-muted mb-2 text-uppercase">Identifier</label>
                                    <input type="text" name="loginId" class="form-control input-compressed w-100" placeholder="ID or Email" required>
                                </div>
                                <div class="mb-4">
                                    <label class="tiny fw-bold text-muted mb-2 text-uppercase">Password</label>
                                    <input type="password" name="password" class="form-control input-compressed w-100" placeholder="********" required>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 py-3 rounded-16 shadow-md fw-bold btn-sm mb-3">Gateway Log In</button>
                            </form>
                            <div class="text-center border-top pt-3">
                                <a href="/auth/forgot-password" class="text-primary text-decoration-none tiny fw-bold"><i class="bi bi-ticket-perforated-fill me-1"></i> Identity Help / Tickets</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notice Board -->
                <div class="col-lg-8 px-lg-5">
                    <div class="mb-5">
                        <span class="section-tag-mini">official board</span>
                        <h2 class="h2 fw-bold text-dark font-outfit mb-2">Notice Board & Memos</h2>
                        <p class="text-muted small">Stay informed with the latest institutional notices and academic bulletins.</p>
                    </div>

                    <div class="d-grid gap-4">
                        <% if (announcements && announcements.length > 0) { %>
                            <% announcements.forEach(item => { %>
                                <div class="notice-card-v d-flex gap-4 align-items-start">
                                    <% if (item.mediaUrl) { %>
                                        <img src="<%= item.mediaUrl %>" class="memo-img-lg shadow-sm border p-1 bg-white">
                                    <% } else { %>
                                        <div class="memo-img-lg bg-light d-flex align-items-center justify-content-center text-muted border">
                                            <i class="bi bi-paperclip fs-1"></i>
                                        </div>
                                    <% } %>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between mb-3">
                                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill tiny fw-bold text-uppercase"><%= item.type %></span>
                                            <span class="tiny text-muted fw-bold"><i class="bi bi-calendar-event me-1"></i> <%= moment(item.createdAt).format('MMM Do, YYYY') %></span>
                                        </div>
                                        <h5 class="fw-bold text-dark mb-3"><%= item.title %></h5>
                                        <p class="text-muted small lh-lg mb-4 opacity-75"><%= item.message %></p>
                                        <button class="btn btn-primary btn-sm rounded-pill px-4 fw-bold tiny">Full Bulletin Details</button>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-5 bg-white rounded-40 border border-dashed">
                                <i class="bi bi-megaphone-fill opacity-25 display-1 d-block mb-3"></i>
                                <span class="text-muted fw-bold">NO NEW INSTITUTIONAL UPDATES FOUND</span>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer-mini border-top">
        <div class="container text-center">
            <div class="d-flex justify-content-center gap-4 mb-4">
                <a href="/privacy" class="text-primary text-decoration-none tiny fw-bold">Privacy Control</a>
                <a href="/terms" class="text-primary text-decoration-none tiny fw-bold">Access Terms</a>
                <a href="mailto:admin@edu.ac.ke" class="text-primary text-decoration-none tiny fw-bold">Support Office</a>
                <a href="mailto:dev@babu-don.com" class="text-primary text-decoration-none tiny fw-bold">Contact Developer</a>
            </div>
            <p class="tiny text-muted opacity-50 mb-0">
                &copy; 2026 EduSmart Academy. All institutional assets managed by <span class="fw-bold text-dark">Babu Don Tech Solutions</span>.
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
